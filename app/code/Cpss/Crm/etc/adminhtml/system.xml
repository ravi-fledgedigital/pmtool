<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="cpss" translate="label" sortOrder="5997">
            <label>CPSS CRM</label>
        </tab>
        <section id="crm" translate="label" type="text" sortOrder="1" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Configuration</label>
            <tab>cpss</tab>
            <resource>Cpss_Crm::config</resource>
            <group id="general" translate="label" type="text" sortOrder="1" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General</label>
                <field id="enable" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="enable_point_checkout_page" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Point Usage in Checkout Page</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="url" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Gateway Url</label>
                    <validate>required-entry validate-url</validate>
                </field>
                <field id="shop_id" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>CPSS Shop ID</label>
                    <comment>If empty, "58001" will be used.</comment>
                </field>
                <field id="site_id" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Site ID</label>
                    <validate>validate-length maximum-length-10</validate>
                    <depends>
                        <field id="crm/general/enable">1</field>
                    </depends>
                </field>
                <field id="cpssmemberid_prefix" translate="label" type="text" sortOrder="35" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>CPSS Member ID Prefix</label>
                    <comment>For test purposes only. Please leave this empty in production.</comment>
                </field>
            </group>
            <group id="membership" translate="label" type="text" sortOrder="2" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>About Member Service</label>
                <!-- WYSIWYG editor field code start-->
                <field id="editor_textarea" translate="label comment" sortOrder="1" type="editor" showInStore="1" showInWebsite="1" showInDefault="1">
                    <label>About</label>
                    <frontend_model>Cpss\Crm\Block\Adminhtml\System\Config\Editor</frontend_model>
                </field>
                <!-- WYSIWYG editor field code end-->
            </group>
            <group id="job_code_configuration" translate="label" type="text" sortOrder="2" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Scode Configuration</label>
                <field id="scodes" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Add Scode</label>
                    <frontend_model>Cpss\Crm\Block\Adminhtml\JobCodeGrid\JobCodes</frontend_model>
                    <backend_model>Cpss\Crm\Config\Backend\AdditionalJobCodes</backend_model>
                </field>
            </group>
            <group id="login_from_apps" translate="label" type="text" sortOrder="1" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Login From Apps</label>
                <field id="app_id" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>App ID</label>
                    <validate>nospace-commaseparated</validate>
                </field>
                <field id="client_id" translate="label" type="text" sortOrder="25" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Client ID</label>
                    <validate>nospace-commaseparated</validate>
                </field>
                <field id="redirect_waiting_time" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Redirect Waiting Time(msec)</label>
                    <validate>positive-integer</validate>
                </field>
                <field id="redirect_to" translate="label" type="text" sortOrder="35" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Redirect after temporary registration</label>
                </field>
                <field id="redirect_to_register" translate="label" type="text" sortOrder="36" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Redirect after full registration</label>
                </field>
                <field id="hash" translate="label" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Hash Key</label>
                </field>
            </group>
        </section>
        <section id="payment">
            <group id="fullpoint" translate="label comment" type="text" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Full Point Payment</label>
                <field id="active" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="title" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Title</label>
                </field>
                <field id="model"></field>
            </group>
        </section>
        <section id="sftp" translate="label" type="text" sortOrder="2" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Sftp</label>
            <tab>cpss</tab>
            <resource>Cpss_Crm::config</resource>
            <group id="cpss" translate="label" type="text" sortOrder="2" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>CPSS</label>
                <field id="host" translate="label" type="text" sortOrder="1" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Host</label>
                </field>
                <field id="username" translate="label" type="text" sortOrder="2" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Username</label>
                </field>
                <field id="method_access" type="select" translate="label" sortOrder="3" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Method Access</label>
                    <source_model>Cpss\Pos\Model\Config\Method</source_model>
                </field>
                <field id="private_key_pem" translate="label comment" type="Cpss\Pos\Model\Config\File\PemFile" sortOrder="4" showInDefault="1" showInWebsite="1">
                    <label>Private Key</label>
                    <config_path>sftp/cpss/private_key</config_path>
                    <backend_model>Cpss\Pos\Model\Config\File\PrivateKeyPem</backend_model>
                    <upload_dir config="system" scope_info="1">pos</upload_dir>
                    <comment><![CDATA[<a href="#" class="cpss-private-key-change-key-type">Change Private Key input method]]></comment>
                </field>
                <field id="private_key_text" translate="label comment" type="textarea" sortOrder="4" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Private Key</label>
                    <config_path>sftp/cpss/private_key</config_path>
                    <frontend_model>Cpss\Pos\Model\Config\Form\Privatekey</frontend_model>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <validate>validate-key</validate>
                    <comment><![CDATA[<a href="#" class="cpss-private-key-change-key-type">Change Private Key input method]]></comment>
                </field>
                <field id="private_key_selected" translate="label comment" type="text" sortOrder="4" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Private Key Selected</label>
                    <frontend_model>Cpss\Pos\Model\Config\Form\PrivateKeySelected</frontend_model>
                </field>
                <field id="private_key_selector" translate="label comment" sortOrder="4" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Private Key</label>
                    <frontend_model>Cpss\Pos\Block\Adminhtml\System\Config\Form\PrivateKeySelector</frontend_model>
                </field>
                <field id="password" translate="label" type="password" sortOrder="5" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Password</label>
                    <depends>
                        <field id="method_access">password</field>
                    </depends>
                </field>
                <field id="port" translate="label" type="text" sortOrder="6" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Port</label>
                </field>
                <field id="in_path" translate="label" type="text" sortOrder="7" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Inbound Path</label>
                    <comment>Please ommit trailing slash in the path value</comment>
                </field>
                <field id="out_path" translate="label" type="text" sortOrder="8" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Outbound Path</label>
                    <comment>Please ommit trailing slash in the path value</comment>
                </field>
            </group>
        </section>
    </system>
</config>
