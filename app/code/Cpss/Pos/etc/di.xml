<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Cpss\Pos\Logger\Handler">
        <arguments>
            <argument name="filesystem" xsi:type="object">Magento\Framework\Filesystem\Driver\File</argument>
        </arguments>
    </type>
    <type name="Cpss\Pos\Logger\Logger">
        <arguments>
            <argument name="name" xsi:type="string">cpssPosLogger</argument>
            <argument name="handlers"  xsi:type="array">
                <item name="system" xsi:type="object">Cpss\Pos\Logger\Handler</item>
            </argument>
        </arguments>
    </type>
    <type name="Cpss\Pos\Logger\CsvLogger">
        <arguments>
            <argument name="name" xsi:type="string">CpssTransferLog</argument>
            <argument name="handlers"  xsi:type="array">
                <item name="system" xsi:type="object">Cpss\Pos\Logger\CsvHandler</item>
            </argument>
        </arguments>
    </type>

    <type name="Magento\Framework\Console\CommandList">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="pos_recovery" xsi:type="object">Cpss\Pos\Model\Recovery\Command</item>
                <item name="getgivenpoint_recovery" xsi:type="object">Cpss\Pos\Model\Recovery\GetGivenPoint</item>
            </argument>
        </arguments>
    </type>
</config>
