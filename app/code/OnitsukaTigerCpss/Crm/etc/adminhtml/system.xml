<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="cpss" translate="label" sortOrder="5997">
            <label>CPSS CRM</label>
        </tab>
        <section id="crm" translate="label" type="text" sortOrder="1" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Configuration</label>
            <tab>cpss</tab>
            <resource>Cpss_Crm::config</resource>
            <group id="general" translate="label" type="text" sortOrder="1" showInDefault="1" showInWebsite="1" showInStore="1">
                <field id="site_password" translate="label comment" type="text" sortOrder="21" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Site Password</label>
                    <validate>validate-length maximum-length-10</validate>
                    <depends>
                        <field id="crm/general/enable">1</field>
                    </depends>
                </field>
                <field id="show_store_purchase" translate="label" type="select" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Show Store Purchase?</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>

            <group id="cpss_point" translate="label" type="text" sortOrder="1" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Point</label>
                <field id="minimum_point" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Minimum Point</label>
                    <validate>nospace-commaseparated</validate>
                </field>
                <field id="per_x_point" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Per X Point</label>
                    <validate>nospace-commaseparated</validate>
                </field>
                <field id="per_x_rate" translate="label" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Per (X) Rate</label>
                    <validate>nospace-commaseparated</validate>
                </field>
                <field id="point_multiple_by" translate="label" type="text" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Point Multiply By</label>
                    <validate>nospace-commaseparated</validate>
                </field>
                <field id="point_earned_multiple_by" translate="label" type="text" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Earned Point Multiply By</label>
                    <validate>nospace-commaseparated</validate>
                </field>
            </group>

            <group id="cpss_minimum_order_amount" translate="label" type="text" sortOrder="1" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Minimum Order Amount configuration</label>
                <field id="world_pay" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>World Pay</label>
                    <validate>nospace-commaseparated</validate>
                </field>
                <field id="razer" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Razer</label>
                    <validate>nospace-commaseparated</validate>
                </field>
                <field id="omise" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Omise</label>
                    <validate>nospace-commaseparated</validate>
                </field>
                <field id="adyen_kakao_pay" translate="label" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Adyen / Kakao Pay</label>
                    <validate>nospace-commaseparated</validate>
                </field>
            </group>
        </section>
        <section id="sftp" translate="label" type="text" sortOrder="2" showInDefault="1" showInWebsite="1" showInStore="1">
            <group id="cpss_email_config" translate="label" type="text" sortOrder="2" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>SFTP Email Template</label>
                <field id="enable" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="receiver_name" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Receiver Name</label>
                </field>
                <field id="receiver_email" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Receiver Email</label>
                    <validate>validate-email</validate>
                </field>
                <field id="pos_sftp_email_template" translate="label comment" type="select" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>POS SFTP Email Template</label>
                    <source_model>Magento\Config\Model\Config\Source\Email\Template</source_model>
                </field>
                <field id="cpss_sftp_email_template" translate="label comment" type="select" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>CPSS SFTP Email Template</label>
                    <source_model>Magento\Config\Model\Config\Source\Email\Template</source_model>
                </field>
            </group>
        </section>
    </system>
</config>
