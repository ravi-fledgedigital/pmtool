<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="customer_account_navigation">
            <block class="Magento\Customer\Block\Account\SortLinkInterface" ifconfig="crm/general/show_store_purchase" name="customer-account-navigation-store-purchase-link">
                <arguments>
                    <argument name="path" xsi:type="string">crm/realstore/purchase</argument>
                    <argument name="label" xsi:type="string" translate="true">Store Purchase</argument>
                    <argument name="sortOrder" xsi:type="number">206</argument>
                </arguments>
            </block>
        </referenceBlock>
    </body>
</page>
