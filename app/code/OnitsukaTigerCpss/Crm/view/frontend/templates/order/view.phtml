                <?php
                    $acquiredPoint = $order->getAcquiredPoint();
                    if ($acquiredPoint <= 0) {
                        $objectManager = \Magento\Framework\App\ObjectManager::getInstance();
                        $configProvider = $objectManager->create(\Cpss\Crm\Model\PointConfigProvider::class);
                        $acquiredPoint = $configProvider->calcAcquiredPointsForRealStore($order->getPurchaseId(), $order->getMemberId());
                    }
                    if ($order->getAddedPointDate() > 0 || $acquiredPoint > 0) {
                        $pointLabel = 'Points to be earned';
                        if ($acquiredPoint <= 0) {
                            $pointValue = $order->getAcquiredPoint();

                            if (($order->getAddedPoint() > 0)) {
                                $pointLabel = 'Added Points';
                                $pointValue = $order->getAddedPoint();
                            }
                        } else {
                            $pointValue = $acquiredPoint;
                        }
                ?>
