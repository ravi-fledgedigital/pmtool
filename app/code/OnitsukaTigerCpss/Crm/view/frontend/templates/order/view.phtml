<script>
    require(['jquery'], function($){
        $(document).ready(function()
        {
            setMobileView();
            $(window).on('resize', function(){
                setMobileView();
            });

            function setMobileView()
            {
                var win = $(this);
                if(win.width() <= 959){
                    $(".table-header-default").hide();
                    $(".table-header-mobile").show();
                    $(".table-row-default").hide();
                    $(".table-row-mobile").show();
                }else{
                    $(".table-header-default").show();
                    $(".table-header-mobile").hide();
                    $(".table-row-default").show();
                    $(".table-row-mobile").hide();
                }
            }
        });
    });
</script>
