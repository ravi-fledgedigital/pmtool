<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="korean_address" translate="label" type="text" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Korea</label>
            <tab>onitsukatiger</tab>
            <resource>OnitsukaTigerKorea_Checkout::config</resource>
            <group id="checkout" translate="label" type="text" sortOrder="1" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Checkout</label>
                <field id="enable" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Enable Module</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>
                        <![CDATA[Select <b>Yes</b> to enable this module.<br />
                        . Enable or disable the module depending on the website (SG, TH, MY, KR)]]>
                    </comment>
                </field>
            </group>
        </section>
        <section id="gift_packaging" sortOrder="10" showInWebsite="1" showInStore="1" showInDefault="1" translate="label">
            <label>Gift Packaging</label>
            <tab>onitsukatiger</tab>
            <resource>OnitsukaTigerKorea_Checkout::config_onitsukatigerkorea_checkout</resource>
            <group id="gift_packaging" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1" translate="label">
                <label>Gift Packaging</label>
                <field id="enable" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1" translate="label">
                    <label>Enable Module</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>
                        <![CDATA[Select <b>Yes</b> to enable this module.<br />
                        . Enable or disable the module depending on the website (SG,TH,MY,KR)]]>
                    </comment>
                </field>
                <field id="prefix_of_skus" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1" translate="label">
                    <label>Prefix of SKU</label>
                    <depends>
                        <field id="enable">1</field>
                    </depends>
                </field>
            </group>
        </section>
    </system>
</config>
