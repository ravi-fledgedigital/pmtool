<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="address_grid" template="OnitsukaTigerKorea_Customer::address/grid.phtml">
            <block class="OnitsukaTigerKorea\Customer\Block\Address\Edit" name="customer_address_edit_popup" as="customer_address_edit_popup" template="OnitsukaTigerKorea_Customer::address/edit-popup.phtml" cacheable="false">
                <arguments>
                    <argument name="attribute_data" xsi:type="object">Magento\Customer\Block\DataProviders\AddressAttributeData</argument>
                    <argument name="post_code_config" xsi:type="object">Magento\Customer\Block\DataProviders\PostCodesPatternsAttributeData</argument>
                </arguments>
            </block>
        </referenceBlock>
    </body>
</page>
