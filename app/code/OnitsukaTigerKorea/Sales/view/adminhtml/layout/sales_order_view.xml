<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="admin-2columns-left"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="column_name" template="OnitsukaTigerKorea_Sales::items/column/name.phtml"/>
        <referenceBlock name="order_history">
            <action method="setTemplate">
                <argument name="template" xsi:type="string">OnitsukaTigerKorea_Sales::order/view/history.phtml
                </argument>
            </action>
        </referenceBlock>
        <referenceBlock name="order_tab_info">
            <action method="setTemplate">
                <argument name="template" translate="true" xsi:type="string">OnitsukaTigerKorea_Sales::order/view/tab/info.phtml</argument>
            </action>
            <block class="OnitsukaTigerKorea\Sales\Block\Adminhtml\Order\View\GiftPackaging" name="gift.packaging.data"
                   template="order/view/gift_packaging.phtml"/>
        </referenceBlock>
    </body>
</page>
