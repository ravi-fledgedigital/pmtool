                        var requestUrl = '<?php echo $block->escapeUrl($klaviyoPixelHelper->getKlaviyoSSTrackUrl()); ?>';
                        $.post({
                            url: requestUrl,
                            global: false,
                            data: {
                                'eventId': klEventIdPlaceOrder,
                                'eventName': '<?= /* @noEscape */ \WeltPixel\GA4\Model\Config\Source\KlaviyoPixel\TrackingEvents::EVENT_PLACED_ORDER  ?>',
                                'OrderURL': window.location.href,
                                'ReferrerURL': document.referrer,
                                'orderId':'<?=  /* @noEscape */ $orderId ?>'
                            }
                        });
                    });
                });
        }
    </script>
<?php endif; ?>
