        if (window.ga4AllowServices) {
            let klaviyoPlacedOrderData = {
                '$value': "<?= /* @noEscape */ /* @noEscape */ $block->getOrderValue() ; ?>",
                'GrandTotal': "<?= /* @noEscape */ /* @noEscape */ $block->getOrderValue() ; ?>",
                'Currency': "<?= /* @noEscape */ $klaviyoPixelHelper->getCurrencyCode() ?>",
                'OrderURL': window.location.href,
                'ReferrerURL': document.referrer,
                'PaymentMethod': '<?= /* @noEscape */ addslashes(str_replace('"', '&quot;', $paymentMethodTitle)) ?>',
                'ShippingMethod': '<?= /* @noEscape */ addslashes(str_replace('"', '&quot;', $block->getOrder()->getShippingDescription())) ?>',
                'OrderTotalQuantity': <?= /* @noEscape */ $block->getOrderNumItems() ?>,
                'Items': <?= /* @noEscape */ $block->getOrderContents() ?>,
                'TransactionId': '<?= /* @noEscape */ $block->getOrder()->getIncrementId() ?>',
                '$event_id': klEventIdPlaceOrder
            }
            klaviyo.track("<?= /* @noEscape */ $klaviyoPixelHelper->getKlaviyoEventName(\WeltPixel\GA4\Model\Config\Source\KlaviyoPixel\TrackingEvents::EVENT_PLACED_ORDER) ?>", klaviyoPlacedOrderData);
        }
    </script>
<?php endif; ?>



<?php if ($klaviyoPixelHelper->isServerSideTrackingEnabled() &&
    $klaviyoPixelHelper->shouldKlaviyoServerSideEventBeTracked(\WeltPixel\GA4\Model\Config\Source\KlaviyoPixel\TrackingEvents::EVENT_PLACED_ORDER) &&
