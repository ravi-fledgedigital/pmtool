<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="before.body.end">
            <!-- Meta Pixel Tracking -->
            <block
                ifconfig="weltpixel_ga4_meta_pixel/general_tracking/enable"
                class="Magento\Catalog\Block\Category\View"
                name="weltpixel_ga4_metapixel_view_category"
                template="WeltPixel_GA4::metapixel/view_category.phtml"
            />
            <!-- Meta Pixel Tracking -->
            <!-- Bing Pixel Tracking -->
            <block
                ifconfig="weltpixel_ga4_bing_pixel/general_tracking/enable"
                class="Magento\Catalog\Block\Category\View"
                name="weltpixel_ga4_bingpixel_view_category"
                template="WeltPixel_GA4::bingpixel/view_category.phtml"
            />
            <!-- Bing Pixel Tracking -->
            <!-- X Pixel Tracking -->
            <block
                ifconfig="weltpixel_ga4_x_pixel/general_tracking/enable"
                class="Magento\Catalog\Block\Category\View"
                name="weltpixel_ga4_x_view_category"
                template="WeltPixel_GA4::xpixel/view_category.phtml"
            />
            <!-- X Pixel Tracking -->
            <!-- Klaviyo Pixel Tracking -->
            <block
                ifconfig="weltpixel_ga4_klaviyo_pixel/general_tracking/enable"
                class="Magento\Catalog\Block\Category\View"
                name="weltpixel_ga4_klaviyopixel_view_category"
                template="WeltPixel_GA4::klaviyopixel/view_category.phtml"
            />
            <!-- X Klaviyo Tracking -->
            <!-- Pinterest Pixel Tracking -->
            <block
                ifconfig="weltpixel_ga4_pinterest_pixel/general_tracking/enable"
                class="Magento\Catalog\Block\Category\View"
                name="weltpixel_ga4_pinterestpixel_view_category"
                template="WeltPixel_GA4::pinterestpixel/view_category.phtml"
            />
            <!-- Pinterest Pixel Tracking -->
        </referenceContainer>
    </body>
</page>
