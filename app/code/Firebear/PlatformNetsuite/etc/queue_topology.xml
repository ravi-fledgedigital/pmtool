<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework-message-queue:etc/topology.xsd">
    <exchange name="netsuite-customer" type="topic" connection="db">
        <binding id="NetsuiteCustomerUpdate" topic="netsuite.customer.update" destinationType="queue" destination="netsuite_customer_update_queue"/>
    </exchange>
    <exchange name="netsuite-customer-address" type="topic" connection="db">
        <binding id="NetsuiteCustomerAddressUpdate" topic="netsuite.customer.address.update" destinationType="queue" destination="netsuite_customer_address_update_queue"/>
    </exchange>
</config>
