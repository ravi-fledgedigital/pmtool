        <field name="tokenSecret" id="tokenSecret" label="Token Secret" type="password" required="true" template="Firebear_PlatformNetsuite/password" />
        <field name="use_old_http_protocol_version"
               id="use_old_http_protocol_version"
               label="Use the HTTP 1.0 protocol version option for the SOAP request"
               type="text"
               formElement="checkbox"
               template="Firebear_PlatformNetsuite/switcher"
               component="Firebear_PlatformNetsuite/js/single-checkbox"/>
    </platform>
