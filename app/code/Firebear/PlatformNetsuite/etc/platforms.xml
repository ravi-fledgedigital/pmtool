    <platform name="netsuiteCategory" entity="catalog_category" label="Netsuite Categories" model="Firebear\PlatformNetsuite\Model\Import\Platform\Category">
        <field name="saved_search_id" id="saved_search_id" label="Saved search id" type="text" required="true" validation="validate-number" />
        <field name="start_page" id="start_page" label="Start Import from Page" type="text" required="true" />
        <field name="end_page" id="end_page" label="Stop Import on Page" type="text" required="false" />
        <field name="endpoint" id="endpoint" label="End point" notice="Example: 2018_2" type="text" required="true" />
        <field name="host" id="host" label="Host" notice="Example: https://webservices.netsuite.com" type="text" required="true" />
        <field name="account" id="account" label="Account" type="text" required="true" />
        <field name="consumerKey" id="consumerKey" label="Consumer Key" type="password" required="true" template="Firebear_PlatformNetsuite/password" />
        <field name="consumerSecret" id="consumerSecret" label="Consumer Secret" type="password" required="true" template="Firebear_PlatformNetsuite/password" />
