<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="customer_account_navigation">
            <block class="Magento\Customer\Block\Account\SortLinkInterface"
                   name="customer-account-navigation-kakao-link"
                   ifconfig="kakaosync/general/enable">
                <arguments>
                    <argument name="path" xsi:type="string">kakaosync/customer/link</argument>
                    <argument name="label" xsi:type="string" translate="true">Kakao Sync</argument>
                    <argument name="sortOrder" xsi:type="number">50</argument>
                </arguments>
            </block>
        </referenceBlock>
    </body>
</page>
