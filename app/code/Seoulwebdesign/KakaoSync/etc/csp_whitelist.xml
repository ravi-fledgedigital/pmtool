<?xml version="1.0"?>
<csp_whitelist xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Csp:etc/csp_whitelist.xsd">
    <policies>
        <policy id="script-src">
            <values>
                 <value id="kakao_developer" type="host">developers.kakao.com</value>
            </values>
        </policy>
        <policy id="img-src">
            <values>
                <value id="kakao_cdn" type="host">k.kakaocdn.net</value>
            </values>
        </policy>
        <policy id="connect-src">
            <values>
                <value id="kakao_auth" type="host">kauth.kakao.com</value>
            </values>
        </policy>
    </policies>
</csp_whitelist>
