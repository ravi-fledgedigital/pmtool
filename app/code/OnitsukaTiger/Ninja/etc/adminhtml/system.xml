<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="onitsukatiger" translate="label" sortOrder="200">
            <label>OnitsukaTiger</label>
        </tab>
        <section id="ninja" translate="label" sortOrder="150" showInDefault="1" showInWebsite="1" showInStore="0">
            <class>separator-top</class>
            <label>Ninja</label>
            <tab>onitsukatiger</tab>
            <resource>OnitsukaTiger_Ninja::config</resource>
            <group id="general" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="0">
                <label>General Configuration</label>
                <field id="enabled" translate="label" type="select" sortOrder="1" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="sandbox" translate="label" type="select" sortOrder="1" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Sandbox Mode</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="client_id" translate="label" sortOrder="2" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Client Id</label>
                </field>
                <field id="client_secret" translate="label" sortOrder="3" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Client Secret</label>
                </field>
                <field id="country_code" translate="label" sortOrder="4" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Country Code</label>
                </field>
                <field id="delivery_end_time" translate="label" sortOrder="5" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Delivery End Time</label>
                </field>
                <field id="pickup_end_time" translate="label" sortOrder="6" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Pickup End Time</label>
                </field>
            </group>
        </section>
        <section id="carriers">
            <group id="ninja" showInDefault="1" showInStore="1" showInWebsite="1" sortOrder="10" translate="label">
                <label>Ninja</label>
                <field id="active" showInDefault="1" showInStore="1" showInWebsite="1" sortOrder="10" translate="label" type="select">
                    <label>Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="title" showInDefault="1" showInStore="1" showInWebsite="1" sortOrder="20" translate="label" type="text" canRestore="1">
                    <label>Title</label>
                </field>
                <field id="name" showInDefault="1" showInStore="1" showInWebsite="1" sortOrder="30" translate="label" type="text" canRestore="1">
                    <label>Method Name</label>
                </field>
                <field id="sallowspecific" showInDefault="1" showInStore="1" showInWebsite="1" sortOrder="50" translate="label" type="select" canRestore="1">
                    <label>Ship to Applicable Countries</label>
                    <frontend_class>shipping-applicable-country</frontend_class>
                    <source_model>Magento\Shipping\Model\Config\Source\Allspecificcountries</source_model>
                </field>
                <field id="specificcountry" showInDefault="1" showInStore="1" showInWebsite="1" sortOrder="60" translate="label" type="multiselect">
                    <label>Ship to Specific Countries</label>
                    <can_be_empty>1</can_be_empty>
                    <source_model>Magento\Directory\Model\Config\Source\Country</source_model>
                </field>
                <field id="showmethod" translate="label" type="select" sortOrder="70" showInDefault="1" showInWebsite="1" showInStore="0" canRestore="1">
                    <label>Show Method if Not Applicable</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <frontend_class>shipping-skip-hide</frontend_class>
                </field>
                <field id="specificerrmsg" showInDefault="1" showInStore="1" showInWebsite="1" sortOrder="80" translate="label" type="textarea" canRestore="1">
                    <label>Displayed Error Message</label>
                </field>
                <field id="condition_name" translate="label" type="select" sortOrder="90" showInDefault="0" showInWebsite="1" showInStore="0" canRestore="1">
                    <label>Condition Shipping Table Rate</label>
                    <source_model>Magento\OfflineShipping\Model\Config\Source\Tablerate</source_model>
                </field>
                <field id="export" translate="label" type="OnitsukaTiger\Ninja\Block\Adminhtml\Form\Field\Export" sortOrder="100" showInDefault="0" showInWebsite="1" showInStore="0">
                    <label>Export Shipping Table Rate</label>
                </field>
                <field id="import" translate="label" type="OnitsukaTiger\Ninja\Block\Adminhtml\Form\Field\Import" sortOrder="105" showInDefault="0" showInWebsite="1" showInStore="0">
                    <label>Import Shipping Table Rate</label>
                    <backend_model>OnitsukaTiger\Ninja\Model\Config\Backend\Tablerate</backend_model>
                </field>
            </group>
        </section>
    </system>
</config>
