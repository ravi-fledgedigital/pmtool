<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="sales_shipment">
        <column xsi:type="varchar" name="cegid_shipment_status" nullable="true" length="255" comment="Status Cron Run"/>
    </table>
    <table name="onitsukatiger_cegid_returnaction" resource="default" engine="innodb"
           comment="onitsukatiger_cegid_returnaction Table">
        <column xsi:type="int" name="returnaction_id" padding="11" unsigned="false" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="int" name="number" padding="10" unsigned="true" nullable="false" identity="false" default="0" comment="Number"/>
        <column xsi:type="varchar" name="stub" nullable="false" length="255" comment="Stub"/>
        <column xsi:type="varchar" name="type" nullable="false" length="255" comment="Type"/>
        <column xsi:type="int" name="request_id" nullable="true"  comment="Request RMA" identity="false"/>
        <column xsi:type="smallint" name="status" padding="6" unsigned="false" nullable="true" identity="false" comment="Status"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="returnaction_id"/>
        </constraint>
        <index referenceId="ONITSUKATIGER_CEGID_RETURN_API" indexType="btree">
            <column name="returnaction_id"/>
        </index>
    </table>
</schema>
