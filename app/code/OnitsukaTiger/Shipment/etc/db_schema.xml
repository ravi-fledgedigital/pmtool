<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="shipment_extension_attributes" resource="default" engine="innodb" comment="Shipment Extension Attributes Tabley">
        <column xsi:type="int" name="shipment_id" unsigned="true" nullable="false"
                identity="false"  comment="Shipment ID"/>
        <index referenceId="ONITSUKATIGER_SHIPMENT_EXTENSION_ATTRIBUTE" indexType="btree">
            <column name="shipment_id"/>
        </index>
        <constraint xsi:type="foreign" referenceId="SHIPMENT_EXTENSION_ATTRIBUTE_SHIPMENT_ID_SALES_SHIPMENT_ENTITY_ID" table="shipment_extension_attributes" column="shipment_id" referenceTable="sales_shipment" referenceColumn="entity_id"/>
    </table>
</schema>
