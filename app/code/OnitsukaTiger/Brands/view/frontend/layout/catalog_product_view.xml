<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="block-variation">
            <block name="product_detail_attr_brands" class="Magento\Catalog\Block\Product\View\Description" template="OnitsukaTiger_Brands::product/view/attribute.phtml" before="-" >
                <arguments>
                    <argument name="at_call" xsi:type="string">getBrands</argument>
                    <argument name="at_code" xsi:type="string">brands</argument>
                    <argument name="css_class" xsi:type="string">brands</argument>
                    <argument name="at_label" xsi:type="string">default</argument>
                    <argument name="at_type" xsi:type="string">text</argument>
                    <argument name="add_attribute" xsi:type="string">itemprop="brands"</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
