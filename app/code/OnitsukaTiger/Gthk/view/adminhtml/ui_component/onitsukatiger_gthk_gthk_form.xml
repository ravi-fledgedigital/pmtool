<?xml version="1.0" ?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
	<argument name="data" xsi:type="array">
		<item name="js_config" xsi:type="array">
			<item name="provider" xsi:type="string">onitsukatiger_gthk_gthk_form.gthk_form_data_source</item>
		</item>
		<item name="label" xsi:type="string" translate="true">General Information</item>
		<item name="template" xsi:type="string">templates/form/collapsible</item>
	</argument>
	<settings>
		<buttons>
			<button name="back" class="OnitsukaTiger\Gthk\Block\Adminhtml\Gthk\Edit\BackButton"/>
			<!--<button name="delete" class="OnitsukaTiger\Gthk\Block\Adminhtml\Gthk\Edit\DeleteButton"/>
			<button name="save" class="OnitsukaTiger\Gthk\Block\Adminhtml\Gthk\Edit\SaveButton"/>
			<button name="save_and_continue" class="OnitsukaTiger\Gthk\Block\Adminhtml\Gthk\Edit\SaveAndContinueButton"/>-->
		</buttons>
		<namespace>onitsukatiger_gthk_gthk_form</namespace>
		<dataScope>data</dataScope>
		<deps>
			<dep>onitsukatiger_gthk_gthk_form.gthk_form_data_source</dep>
		</deps>
	</settings>
	<dataSource name="gthk_form_data_source">
		<argument name="data" xsi:type="array">
			<item name="js_config" xsi:type="array">
				<item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
			</item>
		</argument>
		<settings>
			<submitUrl path="*/*/save"/>
		</settings>
		<dataProvider name="gthk_form_data_source" class="OnitsukaTiger\Gthk\Model\Gthk\DataProvider">
			<settings>
				<requestFieldName>gthk_id</requestFieldName>
				<primaryFieldName>gthk_id</primaryFieldName>
			</settings>
		</dataProvider>
	</dataSource>
	<fieldset name="general">
		<settings>
			<label>General</label>
		</settings>
		<field name="Order_id" formElement="textarea" sortOrder="10">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">Gthk</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">Order Id</label>
				<dataScope>Order_id</dataScope>
                <disabled>true</disabled>
				<validation>
					<rule name="required-entry" xsi:type="boolean">false</rule>
				</validation>
			</settings>
		</field>
		<field name="shipment_id" formElement="textarea" sortOrder="20">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">Gthk</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">Shipment Id</label>
				<dataScope>shipment_id</dataScope>
                <disabled>true</disabled>
				<validation>
					<rule name="required-entry" xsi:type="boolean">false</rule>
				</validation>
			</settings>
		</field>
		<field name="tracking_id" formElement="textarea" sortOrder="30">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">Gthk</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">Tracking Id</label>
				<dataScope>tracking_id</dataScope>
                <disabled>true</disabled>
				<validation>
					<rule name="required-entry" xsi:type="boolean">false</rule>
				</validation>
			</settings>
		</field>
		<field name="created_at" formElement="textarea" sortOrder="40">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">Gthk</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">Created At</label>
				<dataScope>created_at</dataScope>
                <disabled>true</disabled>
                <validation>
					<rule name="required-entry" xsi:type="boolean">false</rule>
				</validation>
			</settings>
		</field>
		<field name="json_data" formElement="textarea" sortOrder="50">
			<argument name="data" xsi:type="array">
				<item name="config" xsi:type="array">
					<item name="source" xsi:type="string">Gthk</item>
				</item>
			</argument>
			<settings>
				<dataType>text</dataType>
				<label translate="true">Json Data</label>
				<dataScope>json_data</dataScope>
                <disabled>true</disabled>
				<validation>
					<rule name="required-entry" xsi:type="boolean">false</rule>
				</validation>
			</settings>
		</field>
	</fieldset>
</form>
