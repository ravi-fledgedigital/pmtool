<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="\Magento\Checkout\Block\Checkout\LayoutProcessor">
        <plugin name="add_custom_field_checkout_form" type="OnitsukaTiger\Checkout\Plugin\Block\Checkout\LayoutProcessor" />
    </type>
    <type name="Magento\Checkout\Api\GuestPaymentInformationManagementInterface">
        <plugin name="disable-guest-place-order" disabled="true"/>
    </type>
    <preference for="Magento\Checkout\Model\Cart\ImageProvider" type="OnitsukaTiger\Checkout\Model\Cart\ImageProvider" />
    <preference for="Magento\Quote\Model\ShippingMethodManagement" type="OnitsukaTiger\Checkout\Model\ShippingMethodManagement" />
    <preference for="Magento\Checkout\Controller\Cart\Delete"
                type="OnitsukaTiger\Checkout\Controller\Cart\Delete" />
</config>
