<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="onitsukatiger_sales" translate="label" type="text" sortOrder="1" showInDefault="1" showInWebsite="1" showInStore="1">
            <class>separator-top</class>
            <label>Sales</label>
            <tab>onitsukatiger</tab>
            <resource>OnitsukaTiger_Sales::config</resource>
            <group id="cronScheduled" translate="label" type="text" sortOrder="1" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Bestseller Updates Frequency</label>
                <field id="scheduled" translate="label comment" sortOrder="3" type="text" showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Scheduled</label>
                    <backend_model>OnitsukaTiger\Catalog\Model\Cron\Config</backend_model>
                    <comment>
                        <![CDATA[
                        <div>
                    * * * * * command to be executed <br/>
                    | | | | | <br/>
                    | | | | +----- Day of week (0 - 7) (Sunday=0 or 7) <br/>
                    | | | +------- Month (1 - 12) <br/>
                    | | +--------- Day of month (1 - 31) <br/>
                    | +----------- Hour (0 - 23) <br/>
                    +------------- Minute (0 - 59)
                        </div>
                        ]]>
                    </comment>
                </field>
            </group>
        </section>
        <section id="coming_soon" translate="label" sortOrder="150" showInDefault="1" showInWebsite="1" showInStore="1">
            <class>separator-top</class>
            <label>Coming Soon</label>
            <tab>onitsukatiger</tab>
            <resource>OnitsukaTiger_Catalog::config</resource>
            <group id="general" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Coming soon configurations</label>
                <field id="coming_soon_label" translate="label" type="text" sortOrder="20" showInDefault="1"
                       showInWebsite="1" showInStore="1">
                    <label>Coming soon label</label>
                </field>
            </group>
        </section>
    </system>
</config>
