<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">
    <event name="checkout_cart_product_add_before">
        <observer name="cart_add_product_validate_qty_sales" instance="OnitsukaTiger\Catalog\Observer\AddProduct"/>
    </event>
    <event name="checkout_cart_update_items_before">
        <observer name="cart_update_product_validate_qty_sales" instance="OnitsukaTiger\Catalog\Observer\UpdateProduct"/>
    </event>
</config>