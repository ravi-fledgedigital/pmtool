<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="portone" resource="default" engine="innodb" comment="PortOne Payment Table">
        <column name="id" xsi:type="int" padding="10" unsigned="true" nullable="false" identity="true" comment="Id" />
        <column name="order_entity_id" xsi:type="int" padding="10" unsigned="true" nullable="false" comment="Sales Order Entity ID" />
        <column name="payment_id" xsi:type="varchar" length="255" nullable="false" comment="Payment ID" />
        <column name="transaction_type" xsi:type="varchar" length="255" nullable="true" comment="Transaction Type" />
        <column name="txid" xsi:type="varchar" length="255" nullable="true" comment="Transaction ID" />
        <column name="status" xsi:type="smallint" unsigned="false" nullable="false" default="0" comment="0 - Failed, 1 - Success, 2 - Cancel/Refund" />
        <column name="full_content" xsi:type="text" nullable="true" comment="Full Response "/>
        <column name="message" xsi:type="text" nullable="true" comment="Message "/>
        <column name="created_at" xsi:type="timestamp" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At" />
        <column name="updated_at" xsi:type="timestamp" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Updated At" />
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="PORTONE_ORDER_ENTITY_ID_SALES_ORDER_ENTITY_ID"
                    table="portone" column="order_entity_id"
                    referenceTable="sales_order" referenceColumn="entity_id"
                    onDelete="CASCADE"/>
    </table>
</schema>
