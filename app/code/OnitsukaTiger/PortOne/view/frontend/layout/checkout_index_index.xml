<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <script src="https://cdn.portone.io/v2/browser-sdk.js" src_type="url"/>
    </head>
    <body>
        <referenceBlock name="checkout.root">
            <arguments>
                <argument name="jsLayout" xsi:type="array">
                    <item name="components" xsi:type="array">
                        <item name="checkout" xsi:type="array">
                            <item name="children" xsi:type="array">
                                <item name="steps" xsi:type="array">
                                    <item name="children" xsi:type="array">
                                        <item name="billing-step" xsi:type="array">
                                            <item name="component" xsi:type="string">uiComponent</item>
                                            <item name="children" xsi:type="array">
                                                <item name="payment" xsi:type="array">
                                                    <item name="children" xsi:type="array">
                                                        <item name="renders" xsi:type="array">
                                                            <!-- merge payment method renders here -->
                                                            <item name="children" xsi:type="array">
                                                                <item name="portone" xsi:type="array">
                                                                    <item name="component" xsi:type="string">OnitsukaTiger_PortOne/js/view/payment/method-renderer</item>
                                                                    <item name="methods" xsi:type="array">
                                                                        <item name="portone" xsi:type="array">
                                                                            <item name="isBillingAddressRequired" xsi:type="boolean">true</item>
                                                                        </item>
                                                                    </item>
                                                                </item>
                                                                <item name="portonetransfer" xsi:type="array">
                                                                    <item name="component" xsi:type="string">OnitsukaTiger_PortOne/js/view/payment/transfer-method-renderer</item>
                                                                    <item name="methods" xsi:type="array">
                                                                        <item name="portonetransfer" xsi:type="array">
                                                                            <item name="isBillingAddressRequired" xsi:type="boolean">true</item>
                                                                        </item>
                                                                    </item>
                                                                </item>
                                                                <item name="portone_easypay" xsi:type="array">
                                                                    <item name="component" xsi:type="string">OnitsukaTiger_PortOne/js/view/payment/easypay-method-renderer</item>
                                                                    <item name="methods" xsi:type="array">
                                                                        <item name="portone_easypay" xsi:type="array">
                                                                            <item name="isBillingAddressRequired" xsi:type="boolean">true</item>
                                                                        </item>
                                                                    </item>
                                                                </item>
                                                                <item name="portone_tosspay" xsi:type="array">
                                                                    <item name="component" xsi:type="string">OnitsukaTiger_PortOne/js/view/payment/tosspay-method-renderer</item>
                                                                    <item name="methods" xsi:type="array">
                                                                        <item name="portone_tosspay" xsi:type="array">
                                                                            <item name="isBillingAddressRequired" xsi:type="boolean">true</item>
                                                                        </item>
                                                                    </item>
                                                                </item>
                                                                <item name="portone_npay" xsi:type="array">
                                                                    <item name="component" xsi:type="string">OnitsukaTiger_PortOne/js/view/payment/npay-method-renderer</item>
                                                                    <item name="methods" xsi:type="array">
                                                                        <item name="portone_npay" xsi:type="array">
                                                                            <item name="isBillingAddressRequired" xsi:type="boolean">true</item>
                                                                        </item>
                                                                    </item>
                                                                </item>
                                                                <item name="portone_kakaopay" xsi:type="array">
                                                                    <item name="component" xsi:type="string">OnitsukaTiger_PortOne/js/view/payment/kakaopay-method-renderer</item>
                                                                    <item name="methods" xsi:type="array">
                                                                        <item name="portone_kakaopay" xsi:type="array">
                                                                            <item name="isBillingAddressRequired" xsi:type="boolean">true</item>
                                                                        </item>
                                                                    </item>
                                                                </item>
                                                                <item name="portonepaycopay" xsi:type="array">
                                                                    <item name="component" xsi:type="string">OnitsukaTiger_PortOne/js/view/payment/paycopay-method-renderer</item>
                                                                    <item name="methods" xsi:type="array">
                                                                        <item name="portonepaycopay" xsi:type="array">
                                                                            <item name="isBillingAddressRequired" xsi:type="boolean">true</item>
                                                                        </item>
                                                                    </item>
                                                                </item>
                                                                <item name="portonesamsungpay" xsi:type="array">
                                                                    <item name="component" xsi:type="string">OnitsukaTiger_PortOne/js/view/payment/samsungpay-method-renderer</item>
                                                                    <item name="methods" xsi:type="array">
                                                                        <item name="portonesamsungpay" xsi:type="array">
                                                                            <item name="isBillingAddressRequired" xsi:type="boolean">true</item>
                                                                        </item>
                                                                    </item>
                                                                </item>
                                                                <item name="portoneapplepay" xsi:type="array">
                                                                    <item name="component" xsi:type="string">OnitsukaTiger_PortOne/js/view/payment/applepay-method-renderer</item>
                                                                    <item name="methods" xsi:type="array">
                                                                        <item name="portoneapplepay" xsi:type="array">
                                                                            <item name="isBillingAddressRequired" xsi:type="boolean">true</item>
                                                                        </item>
                                                                    </item>
                                                                </item>
                                                            </item>
                                                        </item>
                                                    </item>
                                                </item>
                                            </item>
                                        </item>
                                    </item>
                                </item>
                            </item>
                        </item>
                    </item>
                </argument>
            </arguments>
        </referenceBlock>
    </body>
</page>
