<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="category" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
            <class>separator-top</class>
            <label>Menu for Mobile</label>
            <tab>onitsukatiger</tab>
            <resource>OnitsukaTiger_MegaMenu::config_megamenu</resource>
            <group id="mobile" translate="label" type="text" sortOrder="1" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Mobile menu Configuration</label>
                <field id="module_enable" translate="label" type="select" sortOrder="1" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="category_ids" translate="label" type="text" showInDefault="1" showInWebsite="1" showInStore="1" sortOrder="10">
                    <label>Add multiple category ids</label>
                    <depends>
                        <field id="module_enable">1</field>
                    </depends>
                    <comment>Please add comma seperated category ids.</comment>
                </field>
            </group>
        </section>
    </system>
</config>