<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="onitsukatiger_sales" translate="label" sortOrder="170" showInDefault="1" showInWebsite="1" showInStore="1">
            <class>separator-top</class>
            <label>Sales</label>
            <tab>onitsukatiger</tab>
            <resource>OnitsukaTiger_Sales::config</resource>
            <group id="sales_creditmemo" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Credit Memo</label>
                <field id="default_checked_send_mail" translate="label comment" sortOrder="10" type="select" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Default Checked Send Mail Of Credit Memo</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>
            <group id="sales_update_invoice_qty" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Invoice qty Update by cron</label>
                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="0" canRestore="1">
                    <label>Enable</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="order_cron_frequency_to_update_qty_invoiced" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Cron Frequency To Update Invoice qty</label>
                    <comment>
                        <![CDATA[
                        <div>
                    * * * * * command to be executed <br/>
                    | | | | | <br/>
                    | | | | +----- Day of week (0 - 7) (Sunday=0 or 7) <br/>
                    | | | +------- Month (1 - 12) <br/>
                    | | +--------- Day of month (1 - 31) <br/>
                    | +----------- Hour (0 - 23) <br/>
                    +------------- Minute (0 - 59)
                        </div>
                        ]]>
                    </comment>
                </field>
                <field id="order_hours_frequency_to_update_qty_invoiced" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Add Hours To Update Blank Order Status</label>
                    <comment>Add hours value in number to update the Invoice qty. (Ex: 1)</comment>
                </field>
                <field id="order_status" translate="label" type="multiselect" sortOrder="40" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Sync Order With Status</label>
                    <source_model>Magento\Sales\Model\Config\Source\Order\Status</source_model>
                </field>
            </group>
        </section>
    </system>
</config>
