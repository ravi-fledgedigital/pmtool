<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">
    <event name="checkout_cart_update_items_before">
        <observer name="qty_check_before_update_cart" instance="OnitsukaTiger\MaxQty\Observer\CartQtyCheck" />
    </event>
    <event name="checkout_cart_product_add_before">
        <observer name="check_max_qty_before_add_product_to_cart" instance="OnitsukaTiger\MaxQty\Observer\MaxQtyCheck" />
    </event>
    <event name="controller_action_predispatch_checkout_cart_index">
        <observer name="max_qty_view_cart_controller_action_predispatch" instance="OnitsukaTiger\MaxQty\Observer\ViewCartMaxQtyCheck" />
    </event>
    <event name="controller_action_predispatch_checkout_index_index">
        <observer name="max_qty_view_cart_controller_action_predispatch" instance="OnitsukaTiger\MaxQty\Observer\ViewCartMaxQtyCheck" />
    </event>
    <event name="controller_action_predispatch_checkout_cart_add">
        <observer name="restrict_add_to_cart_controller_action_predispatch" instance="OnitsukaTiger\MaxQty\Observer\RestrictAddToCart"/>
    </event>
</config>
