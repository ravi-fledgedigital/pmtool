<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="onitsukatiger" translate="label" sortOrder="200">
            <label>OnitsukaTiger</label>
        </tab>
        <section id="refund_online" translate="label" sortOrder="130" showInDefault="1" showInWebsite="1" showInStore="1">
            <class>separator-top</class>
            <label>Refund Online</label>
            <tab>onitsukatiger</tab>
            <resource>OnitsukaTiger_Omise::configuration</resource>
            <group id="general" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General Configuration</label>
                <field id="omise_refund_online_enabled" translate="label" type="select" sortOrder="6" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Omise Refund Online Enable</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>
        </section>
        <section id="payment">
            <group id="omise">
                <field id="omise_cron_frequency_to_update_blank_order_status" translate="label comment" type="text" sortOrder="73" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Cron Frequency To Update Blank Order Status</label>
                </field>
                <field id="omise_hours_to_update_blank_order_status" translate="label comment" type="text" sortOrder="74" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Add Hours To Update Blank Order Status</label>
                    <comment>Add hours value in number to update the blank order status. (Ex: 1)</comment>
                </field>
            </group>
        </section>
    </system>
</config>
