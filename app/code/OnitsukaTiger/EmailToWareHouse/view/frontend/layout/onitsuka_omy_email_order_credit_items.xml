<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd" label="Email OMY Credit Items List" design_abstraction="custom">
    <update handle="onitsuka_email_order_credit_renderers"/>
    <update handle="sales_email_item_price"/>
    <body>
        <block class="Magento\Sales\Block\Order\Email\Creditmemo\Items" name="items" template="OnitsukaTiger_EmailToWareHouse::email/credit/omy_items.phtml">
            <block class="Magento\Framework\View\Element\RendererList" name="onitsuka.email.order.credit.renderers" as="renderer.list"/>
            <block class="Magento\Sales\Block\Order\Creditmemo\Totals" name="credit_totals" template="OnitsukaTiger_EmailToWareHouse::order/totals.phtml" cacheable="false"/>
        </block>
        <block class="Magento\Framework\View\Element\Template" name="additional.product.info" template="Magento_Theme::template.phtml"/>
    </body>
</page>
