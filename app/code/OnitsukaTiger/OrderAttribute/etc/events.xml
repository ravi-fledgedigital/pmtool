<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">

    <event name="sales_model_service_quote_submit_before">
        <observer instance="OnitsukaTiger\OrderAttribute\Observer\ConvertQuoteToOrder" name="ConvertQuoteAttributesToOrderAttributes"/>
    </event>
    <event name="sales_convert_quote_to_order">
        <observer instance="OnitsukaTiger\OrderAttribute\Observer\ConvertQuoteToOrder" name="ConvertQuoteAttributesToOrderAttributes"/>
    </event>
    <event name="sales_convert_order_to_quote">
        <observer instance="OnitsukaTiger\OrderAttribute\Observer\ConvertOrderToQuote" name="ConvertOrderAttributesToQuoteAttributes"/>
    </event>
    <event name="sales_order_place_after">
        <observer instance="OnitsukaTiger\OrderAttribute\Observer\NewsletterSubscriber" name="SubscribeToNewsletterByOrderAttribute"/>
    </event>
</config>
