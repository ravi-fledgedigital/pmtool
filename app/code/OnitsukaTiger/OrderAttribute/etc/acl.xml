<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Magento_Sales::sales">
                    <resource id="Magento_Sales::sales_operation">
                        <resource id="OnitsukaTiger_OrderAttribute::order_attributes" title="OnitsukaTiger Order Attributes" sortOrder="40"/>
                        <resource id="OnitsukaTiger_OrderAttribute::attributes_relation" title="Manage OnitsukaTiger Order Attribute Relations" sortOrder="50"/>
                        <resource id="Magento_Sales::sales_order">
                            <resource id="Magento_Sales::actions">
                                <resource id="OnitsukaTiger_OrderAttribute::attribute_value_edit" translate="title" title="Edit OnitsukaTiger Order Attributes" sortOrder="50"/>
                            </resource>
                        </resource>
                    </resource>
                </resource>
                <resource id="Magento_Backend::stores">
                    <resource id="Magento_Backend::stores_settings">
                        <resource id="Magento_Config::config">
                            <resource id="OnitsukaTiger_OrderAttribute::attribute"
                                      title="OnitsukaTiger Order Attributes"
                                      sortOrder="151801" />
                        </resource>
                    </resource>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
