<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="sales_order_status_tracking" resource="default" engine="innodb" comment="Sales Flat Order Status Tracking Table">
        <column xsi:type="int" name="entity_id" unsigned="true" padding="10" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="int" name="parent_id" unsigned="true" padding="10" nullable="false" comment="Parent ID"/>
        <column xsi:type="varchar" name="status" length="32" nullable="false" comment="Status"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <index referenceId="SALES_ORDER_STATUS_TRACKING_PARENT_ID" indexType="btree">
            <column name="parent_id"/>
        </index>
    </table>
</schema>
