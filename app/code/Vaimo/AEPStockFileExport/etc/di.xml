<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <virtualType name="AdobeCampaignStocksConfigProvider" type="Vaimo\AEPFileExport\Model\ConfigProvider">
        <arguments>
            <argument name="folderConfigPath" xsi:type="string">aep_stock_file_export/adobe_campaign/folder_path</argument>
            <argument name="filenameConfigPath" xsi:type="string">aep_stock_file_export/adobe_campaign/filename</argument>
            <argument name="schedulerEnabledConfigPath" xsi:type="string">aep_stock_file_export/adobe_campaign/scheduler_enabled</argument>
        </arguments>
    </virtualType>
    <virtualType name="StockAdobeCampaignExportService" type="Vaimo\AEPFileExport\Model\Service\Export">
        <arguments>
            <argument name="export" xsi:type="object">Vaimo\AEPStockFileExport\Model\Export\Stock</argument>
            <argument name="configProvider" xsi:type="object">AdobeCampaignStocksConfigProvider</argument>
            <argument name="writerDestination" xsi:type="string">aep_export/adobe_campaign_stocks.csv</argument>
        </arguments>
    </virtualType>
    <type name="Vaimo\AEPStockFileExport\Console\Command\ProxyWrapper">
        <arguments>
            <argument name="state" xsi:type="object">Magento\Framework\App\State\Proxy</argument>
            <argument name="export" xsi:type="object">StockAdobeCampaignExportService</argument>
        </arguments>
    </type>
    <type name="Vaimo\AEPStockFileExport\Console\Command\Command">
        <arguments>
            <argument name="export" xsi:type="object">Vaimo\AEPStockFileExport\Console\Command\ProxyWrapper\Proxy</argument>
        </arguments>
    </type>
    <type name="Magento\Framework\Console\CommandListInterface">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="aep-file-export-adobe-campaign-stocks" xsi:type="object">Vaimo\AEPStockFileExport\Console\Command\Command</item>
            </argument>
        </arguments>
    </type>
    <type name="Vaimo\AEPStockFileExport\Cron\ExportStocks">
        <arguments>
            <argument name="export" xsi:type="object">StockAdobeCampaignExportService</argument>
            <argument name="configProvider" xsi:type="object">AdobeCampaignStocksConfigProvider</argument>
        </arguments>
    </type>
</config>
