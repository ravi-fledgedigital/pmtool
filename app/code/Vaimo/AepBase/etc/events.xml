<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">
    <event name="wishlist_product_add_after">
        <observer name="Vaimo_AepBase" instance="Vaimo\AepBase\Observer\WishlistAddObserver" />
    </event>
    <event name="wishlist_save_after">
        <observer name="Vaimo_AepBase" instance="Vaimo\AepBase\Observer\WishlistSaveObserver" />
    </event>
    <event name="checkout_cart_add_product_complete">
        <observer name="addtocart_after" instance="Vaimo\AepBase\Observer\ProductAddAfterObserver" />
    </event>
    <event name="checkout_cart_save_after">
        <observer name="updatecart" instance="Vaimo\AepBase\Observer\UpdateCartAfterObserver" />
    </event>
</config>
