<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
  <table name="onitsukatigerindo_rmaaccount" resource="default" engine="innodb" comment="Biren Crudimage Table">
    <column xsi:type="int" name="rma_id" padding="10" unsigned="true" nullable="false" identity="true" comment="Entity Id"/>
    <column xsi:type="varchar" name="order_number" nullable="true" length="255" comment="Order Number"/>
    <column xsi:type="varchar" name="acc_holder_name" nullable="true" length="255" comment="Account Holder Name"/>
    <column xsi:type="varchar" name="bank_name" nullable="true" length="255" comment="Bank Name"/>
    <column xsi:type="varchar" name="account_number" nullable="true" length="255" comment="Account Number"/>
    <column xsi:type="varchar" name="ifsc_code" nullable="true" length="255" comment="IFSC"/>
    <!--<column xsi:type="varchar" name="image" nullable="true" length="255" comment="Image"/>-->
    <column xsi:type="timestamp" name="created_at" on_update="true" nullable="true" default="CURRENT_TIMESTAMP" comment="Created At"/>
    <constraint xsi:type="primary" referenceId="PRIMARY">
      <column name="rma_id"/>
    </constraint>
  </table>
</schema>
