<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
        
    <table name="sales_order" resource="default" engine="innodb">
        <column xsi:type="varchar" name="biteship_order_id" nullable="true" length="40" comment="Biteship Order Id"/>
        <column xsi:type="varchar" name="courier_waybill_id" nullable="true" length="40" comment="Courier Waybill Id"/>
    </table>

    <table name="sales_order_grid" resource="default" engine="innodb">
        <column xsi:type="varchar" name="biteship_order_id" nullable="true" length="40" comment="Biteship Order Id"/>
        <column xsi:type="varchar" name="courier_waybill_id" nullable="true" length="40" comment="Courier Waybill Id"/>
    </table>
</schema>