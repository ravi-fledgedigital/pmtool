<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
	<preference for="OnitsukaTigerIndo\Biteship\Api\BiteshipOrderStatusInterface" type="OnitsukaTigerIndo\Biteship\Model\BiteshipOrderStatus" />
	<type name="Magento\Framework\Console\CommandList">
		<arguments>
			<argument name="commands" xsi:type="array">
				<item name="sales_order_sync_to_biteship" xsi:type="object">OnitsukaTigerIndo\Biteship\Console\SyncOrderToBiteship</item>
			</argument>
		</arguments>
	</type>

    <virtualType name="Magento\Sales\Model\ResourceModel\Order\Grid" type="Magento\Sales\Model\ResourceModel\Grid">
        <arguments>
            <argument name="columns" xsi:type="array">
                <item name="biteship_order_id" xsi:type="string">sales_order.biteship_order_id</item>
            </argument>
        </arguments>
    </virtualType>
    <preference for="Magento\OfflineShipping\Model\Carrier\Flatrate" type="OnitsukaTigerIndo\Biteship\Model\Carrier\Flatrate" />
</config>