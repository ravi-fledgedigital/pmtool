<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="directory_country_cities" resource="default" engine="innodb"
           comment="Directory Country Cities Table">
        <column xsi:type="int" name="entity_id" padding="11" unsigned="false" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="int" name="city_id" unsigned="true" nullable="false" padding="11" comment="City Id"/>
        <column xsi:type="varchar" name="province_code" nullable="false" length="255" comment="Province Code"/>
        <column xsi:type="varchar" name="city_name" nullable="false" length="255" comment="City Name"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
    </table>
    <table name="directory_country_district" resource="default" engine="innodb"
           comment="Directory Country District Table">
        <column xsi:type="int" name="entity_id" padding="11" unsigned="false" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="int" name="city_id" unsigned="true" nullable="false" padding="11" comment="City Id"/>
        <column xsi:type="varchar" name="district_id" nullable="false" length="255" comment="District Id"/>
        <column xsi:type="varchar" name="district_name" nullable="false" length="255" comment="District Name"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
    </table>
</schema>
