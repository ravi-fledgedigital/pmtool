?>
<div class="<?= $block->escapeHtmlAttr($fieldCssClass) ?>">
    <label class="label" for="<?= /* @noEscape */ $block->getHtmlId() ?>"><span><?= $block->escapeHtml($block->getStoreLabel('dob')) ?></span></label>
    <div class="control customer-dob my-account-dob">
        <?php if($block->getDob() && (isset($linkStatus['id']))) {?>
            <input type="text" name="dob" id="dob" value="<?= $block->getDob() ?>" class="" style="pointer-events: none;background-color: #f5f5f5;color: #888;border: 1px solid #ccc;" />
        <?php } else { ?>
            <?= $block->getFieldHtml() ?>
        <?php } ?>
        <?php if ($_message = $block->getAdditionalDescription()) : ?>
            <div class="note"><?= $block->escapeHtml($_message) ?></div>
        <?php endif; ?>
        <div class="validation-age hidden mage-error" generated="true">
            <span><?= __('You must be at least fourteen (14) years of age to subscribe.')?></span>
        </div>
    </div>
</div>

<script type="text/x-magento-init">
    {
        "*": {
           "Magento_Customer/js/validation": {}
       }
    }
</script>
<script type="text/javascript">
    require(['jquery', 'domReady!'], function ($) {
        var dataForm = $('#form-validate');
        dataForm.find('.validation-age').hide();
        $('.form-create-account button.submit, .form-edit-account button.save').on("click", function (e) {
            var dateCustomer = $('.customer-dob #dob').val();
            var today = new Date();
            var birthDate = new Date(dateCustomer);
            var age = today.getFullYear() - birthDate.getFullYear();
            var m = today.getMonth() - birthDate.getMonth();
            if (m < 0 || (m === 0 && today.getDate() < birthDate.getDate())) {
                age--;
            }
            if (age < 14) {
                dataForm.find('.validation-age').show();
                return false;
            } else {
                dataForm.find('.validation-age').hide();
            }
        })
    });
</script>
