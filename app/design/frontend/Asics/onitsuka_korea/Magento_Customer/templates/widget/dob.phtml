if ($customerSession->isLoggedIn()) {
    $customer = $customerSession->getCustomer();
    if ($customer && $customer->getId()) {
        $isKakaoLogin = $customer->getIsKakaoLogin();
    }
}

$fieldCssClass = 'field date field-' . $block->getHtmlId();
