/** @var \Magento\Customer\Block\Widget\Gender $block */
/** @var \Magento\Framework\App\RequestInterface $request */
$request = \Magento\Framework\App\ObjectManager::getInstance()->get(\Magento\Framework\App\RequestInterface::class);
$isEditAccountPage = ($request->getFullActionName() === 'customer_account_edit');
/** @var \Magento\Customer\Model\Session $customerSession */
$isKakaoLogin = 0;
$customerSession = \Magento\Framework\App\ObjectManager::getInstance()->get(\Magento\Customer\Model\Session::class);
if ($customerSession->isLoggedIn()) {
    $customer = $customerSession->getCustomer();
    if ($customer && $customer->getId()) {
        $isKakaoLogin = $customer->getIsKakaoLogin();
    }
}
$linkBlock = $block->getLayout()->createBlock(Seoulwebdesign\KakaoSync\Block\Customer\Link::class);
$linkStatus = $linkBlock->getLinkStatus();
