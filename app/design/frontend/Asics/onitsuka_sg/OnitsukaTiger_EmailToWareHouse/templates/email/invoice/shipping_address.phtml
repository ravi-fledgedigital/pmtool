<?php /** @var $block \OnitsukaTiger\EmailToWareHouse\Block\Order\Email\Invoice\Address */ ?>
<?php
$_order = $block->getOrder();
$shippingAddress = $_order->getShippingAddress();
?>

<span class="address"><?= $block->escapeHtml($block->getName($shippingAddress)) ?></span><br>
<?php foreach ($block->getStreet($shippingAddress) as $street) : ?>
    <span class="address"><?= $block->escapeHtml($street) ?></span><br>
<?php endforeach; ?>
<p class="address country"><?= $block->escapeHtml($block->getCountry($shippingAddress)) ?>, <?= $block->escapeHtml($block->getPostCode($shippingAddress)) ?></p>
<span class="address"><?= $block->escapeHtml($block->getTelephone($shippingAddress)) ?></span><br>
<span class="address"><?= $block->escapeHtml($block->getEmail($shippingAddress)) ?></span><br>
