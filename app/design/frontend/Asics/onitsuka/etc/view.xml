<view xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Config/etc/view.xsd">
    <media>
        <images module="Magento_Catalog">
            <image id="swatch_image" type="swatch_image">
                <width>105</width>
                <height>78</height>
            </image>
            <image id="category_page_grid" type="small_image">
                <width>300</width>
                <height>210</height>
            </image>
            <image id="swatch_image_base" type="swatch_image">
                <width>105</width>
                <height>78</height>
            </image>
            <image id="category_page_grid_base_second" type="base_mouseover_image">
                <width>300</width>
                <height>211</height>
            </image>
            <image id="category_page_grid_base" type="small_image">
                <width>300</width>
                <height>211</height>
            </image>
            <image id="product_page_image_small" type="thumbnail">
                <width>1280</width>
                <height>1452</height>
            </image>
        </images>
    </media>
    <vars module="Magento_Catalog">
        <var name="gallery">
            <var name="transition">
                <var name="effect">slide</var> <!-- Sets transition effect for slides changing (slide/crossfade/dissolve) -->
            </var>
        </var>
        <var name="breakpoints">
            <var name="mobile">
                <var name="options">
                    <var name="options">
                        <var name="allowfullscreen">false</var>
                    </var>
                </var>
            </var>
        </var>
    </vars>
    <vars module="Js_Bundle">
        <var name="bundle_size">2MB</var>
    </vars>
    <exclude>
        <item type="directory">Sapient_Worldpay::js/lib</item>
    </exclude>
</view>
