use Magento\CatalogSearch\Block\Result;

/** These changes need to valid applying filters and configuration before search process is started. */

/** @var $block  Result*/
$productList = $block->getProductListHtml();
?>

<?php if ($block->getResultCount()) : ?>
    <?= /* @noEscape */ $block->getChildHtml('tagged_product_list_rss_link') ?>
    <?php if ($messages = $block->getNoteMessages()) : ?>
        <div class="message notice">
            <div>
                <?php foreach ($messages as $message) : ?>
                    <?= /* @noEscape */ $message ?><br />
                <?php endforeach; ?>
            </div>
        </div>
    <?php endif; ?>
    <?= /* @noEscape */ $productList ?>
    <style>
        .page-layout-2columns-left .page-main {
            margin-top: 58px;
        }
    </style>
<?php else : ?>
    <?php $helper = $this->helper('\Magento\CatalogSearch\Helper\Data');?>
    <div class="search-product-empty">
        <ul class="heading-search">
            <li><?= __('Search Results')?></li>
            <li class="successmsg">
                <?= __('We\'re sorry, no products were found for your search: ')?> <?= $helper->getEscapedQueryText(); ?>
            </li>
        </ul>
        <div class="search-empty-container">
            <ul>
                <li><?= __('Try your search again using these tips:')?></li>
            </ul>
            <ul class="searchtips">
                <li><?= __('Double check the spelling')?></li>
                <li><?= __('Change your search query')?></li>
                <li><?= __('Use a more general term')?></li>
            </ul>
        </div>
    </div>
    <style>
        .page-layout-2columns-left .column.main {
            width: 100%;
        }
        .page-products.page-layout-2columns-left .sidebar-main {
            display: none;
        }
    </style>
<?php endif; ?>
