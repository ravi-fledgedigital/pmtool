<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>        
        <referenceContainer name="main">
            <container htmlTag="div" htmlClass="finder-main" before="-">
                <block class="Magento\Cms\Block\Block" name="message-store-locator-block">
                    <arguments>
                        <argument name="block_id" xsi:type="string">message-store-locator-block</argument>
                    </arguments>
                </block>
            </container>
        </referenceContainer>
        <referenceBlock name="message-store-locator" remove="true"/>
    </body>
</page>