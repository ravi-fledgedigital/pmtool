// phpcs:disable Magento2.Templates.ThisInTemplate.FoundThis

/**
 * Product description template
 *
 * @var $block \Magento\Catalog\Block\Product\View\Description
 */
$description =  $this->helper(Magento\Catalog\Helper\Output::class)->productAttribute(
    $block->getProduct(),
    $block->getProduct()->getDescription(),
    'description'
);
?>
<?php if ($description): ?>
    <div class="show_popup_description">
        <span id="show_modal_description"><?= __('SEE MORE')?></span>
        <div id="content_des">
            <?= /* @noEscape */ $description ?>
        </div>
    </div>
    <script>
        require(
            [
                'jquery',
                'Magento_Ui/js/modal/modal'
            ],
            function($, modal) {
                var options = {
                    type: 'popup',
                    responsive: true,
                    innerScroll: true,
                    modalClass: 'product-description-modals',
                    buttons: [{
                        text: $.mage.__('Close'),
                        class: 'modal-close',
                        click: function (){
                            this.closeModal();
                        }
                    }]
                };

                modal(options, $("#content_des"));
                $('.block-variation-container .product.attribute.description').show();
                $("#show_modal_description").on('click',function(){
                    $("#content_des").modal("openModal").show();
                });
            }
        );
    </script>
<?php endif; ?>
