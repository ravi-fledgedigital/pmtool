<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="2columns-left" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="div.sidebar.additional">
            <block class="Magento\Framework\View\Element\Template" before="-" template="Magento_Catalog::filter-mobile.phtml"/>
        </referenceContainer>
        <referenceContainer name="main">
            <container htmlTag="div" htmlClass="category-box sp-only" after="-">
                <block class="Magento\Cms\Block\Block" name="category-box-links">
                    <arguments>
                        <argument name="block_id" xsi:type="string">category-box-links</argument>
                    </arguments>
                </block>
            </container>
        </referenceContainer>
        <referenceBlock name="head.additional">
            <block class="Magento\Theme\Block\Html\Header\Logo" name="category.opengraph.general" template="Magento_Catalog::category/view/opengraph/general.phtml"/>
        </referenceBlock>
        <referenceContainer name="content">
            <referenceBlock name="category.products.list">
                <arguments>
                    <argument name="view_model" xsi:type="object">Vaimo\OTScene7Integration\ViewModel\ResizeImage</argument>
                </arguments>
            </referenceBlock>
        </referenceContainer>
    </body>
</page>
