<div class="message-qty-validate"><span></span></div>


<script>
    require([
        'jquery',
        'domReady!'
    ], function ($) {
        $(document).ready(function () {
            var intervalId = window.setInterval(function(){
                if ($('.swatch-option.image.other-color-options.selected').length) {
                    var firstVar = $('.swatch-option.image.other-color-options.selected');
                    firstVar.removeClass('selected');
                    firstVar.trigger('click');
                    clearInterval(intervalId);
                }
            }, 1000);
        });

        $(document).on('click','#swatch-qa-size-options', function (e) {
            if (!$(this).hasClass("ot-size-options")) {
                $(this).toggleClass('active-visible');
            }
        });
    });
</script>
