                "currentPageUrl":"<?=
                    /* @noEscape */ $block->getUrl('*/*/*', ['_current' => true, '_use_rewrite' => true])
                ?>",
                "storeId": "<?= /* @noEscape */ $storeId; ?>",
                "mageLoaderImg": "<?= /* @noEscape */ $mageLaoderImg; ?>"
            }
