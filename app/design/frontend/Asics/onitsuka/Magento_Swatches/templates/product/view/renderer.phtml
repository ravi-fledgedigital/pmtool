                "colorAttrId": <?= /* @noEscape */ $colorAttrId ?>,
                "sizeAttrId": <?= /* @noEscape */ $sizeAttrId ?>,
                "productId": "<?= /* @noEscape */ $block->getProduct()->getId(); ?>",
                "productSku": "<?= /* @noEscape */ $block->getProduct()->getSku(); ?>",
                "styleCode": "<?= /* @noEscape */ $block->getProduct()->getStyleCode(); ?>",
