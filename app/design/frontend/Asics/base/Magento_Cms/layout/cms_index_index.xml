<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="root">
            <block class="Magento\Newsletter\Block\Subscribe" name="newsletter-popup-main" after="-" template="Magento_Theme::html/newsletter-init.phtml">
                <block class="Magento\Cms\Block\Block" name="newsletter-popup" after="-">
                    <arguments>
                        <argument name="block_id" xsi:type="string">newsletter-popup</argument>
                    </arguments>
                </block>
            </block>
        </referenceContainer>
    </body>
</page>
