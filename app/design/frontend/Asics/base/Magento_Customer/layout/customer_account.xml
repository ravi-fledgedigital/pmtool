<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="2columns-left" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd" label="Customer My Account (All Pages)" design_abstraction="custom">
    <body>
        <referenceBlock name="customer-account-navigation-account-edit-link">
            <arguments>
                <argument name="label" xsi:type="string" translate="true">Personal Information</argument>
                <argument name="sortOrder" xsi:type="number">250</argument>
            </arguments>
        </referenceBlock>
        <referenceBlock name="customer-account-navigation-address-link">
            <arguments>
                <argument name="label" xsi:type="string" translate="true">My Saved Addresses</argument>
                <argument name="sortOrder" xsi:type="number">220</argument>
            </arguments>
        </referenceBlock>
        <referenceBlock name="customer-account-navigation-account-link">
            <arguments>
                <argument name="label" xsi:type="string" translate="true">My Profile</argument>
            </arguments>
        </referenceBlock>
        <move element="page.main.title" destination="main" before="-"/>
        <referenceContainer name="div.sidebar.additional" remove="true"/>
        <referenceContainer name="address_book" remove="true"/>
        <referenceBlock name="customer-account-navigation-downloadable-products-link" remove="true"/>
        <referenceBlock name="customer-account-navigation-delimiter-1" remove="true"/>
        <referenceBlock name="customer-account-navigation-delimiter-2" remove="true"/>
        <referenceBlock name="customer-account-navigation-my-credit-cards-link" remove="true"/>
        <referenceBlock name="customer-account-navigation-product-reviews-link" remove="true"/>
        <referenceBlock name="customer-account-navigation-worldpay-subscriptions" remove="true"/>
        <referenceBlock name="customer_account_navigation_saved_Card" remove="true"/>
    </body>
</page>
