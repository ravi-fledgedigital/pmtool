<page layout="1column" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="product.info.sku">
            <arguments>
                <argument name="at_label" xsi:type="string" translate="true">style:</argument>
            </arguments>
        </referenceBlock>
        <referenceBlock name="product.info.description">
            <arguments>
                <argument name="title" translate="true" xsi:type="string">Product Details</argument>
            </arguments>
        </referenceBlock>
        <referenceBlock name="product.info.description">
            <arguments>
                <argument name="title" translate="true" xsi:type="string">Product Details</argument>
            </arguments>
        </referenceBlock>
        <referenceContainer name="content">
            <block class="Magento\Framework\View\Element\Template" name="product.init.zoom" after="-" template="Magento_Catalog::product/view/init-zoom.phtml"/>
        </referenceContainer>
        <move element="page.main.title" destination="product.info.main" before="-"/>
        <referenceBlock name="product.attributes" remove="true" />
        <referenceBlock name="reviews.tab" remove="true" />
    </body>
</page>
