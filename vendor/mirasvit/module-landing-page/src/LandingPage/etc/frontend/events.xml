<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">
    <event name="controller_action_postdispatch_catalogsearch_result_index">
        <observer name="mst_landing_page_catalogsearch" instance="Mirasvit\LandingPage\Observer\RedirectOnCatalogSearchPageObserver" />
    </event>
    <event name="controller_action_postdispatch_catalog_category_view">
        <observer name="mst_landing_page_category" instance="Mirasvit\LandingPage\Observer\RedirectOnCategoryPageObserver" />
    </event>
    <event name="controller_action_postdispatch_all_products_page_index_index">
        <observer name="mst_landing_page_all_products" instance="Mirasvit\LandingPage\Observer\RedirectOnAllProductsPageObserver" />
    </event>
</config>
