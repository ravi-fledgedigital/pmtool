<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Mirasvit\LandingPage\Ui\Page\Form\DataProvider">
        <arguments>
            <argument name="imageUploader" xsi:type="object">Mirasvit\LandingPage\ImageUploader</argument>
        </arguments>
    </type>
    <type name="Mirasvit\LandingPage\Controller\Adminhtml\Page\ImageUpload">
        <arguments>
            <argument name="imageUploader" xsi:type="object">Mirasvit\LandingPage\ImageUploader</argument>
        </arguments>
    </type>

    <type name="Magento\Framework\View\Element\Message\MessageConfigurationsPool">
        <arguments>
            <argument name="configurationsMap" xsi:type="array">
                <item name="mstLandingPageReindexMessage" xsi:type="array">
                    <item name="renderer" xsi:type="const">\Magento\Framework\View\Element\Message\Renderer\BlockRenderer::CODE</item>
                    <item name="data" xsi:type="array">
                        <item name="template" xsi:type="string">Mirasvit_LandingPage::messages/reindex_notice.phtml</item>
                    </item>
                </item>
            </argument>
        </arguments>
    </type>
</config>
