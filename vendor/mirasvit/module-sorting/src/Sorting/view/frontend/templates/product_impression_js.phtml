<script>
    document.addEventListener("DOMContentLoaded", () => {

        const id      = <?php /* @noEscape */ echo $block->getProductId(); ?>;
        let actionUrl = '<?php /* @noEscape */ echo $block->getImpressionUrl(); ?>';
        actionUrl     = actionUrl + '?id=' + id;

        fetch(actionUrl, {
            method: "get"
        });
    });
</script>