<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">
    <event name="catalog_product_save_after">
        <observer name="mstSortingSavePinnedProducts" instance="Mirasvit\Sorting\Observer\SavePinnedProductsObserver"/>
    </event>

    <event name="catalog_category_save_after">
        <observer name="mstSortingSaveCategoryPinnedProducts" instance="Mirasvit\Sorting\Observer\SaveCategoryPinnedProductsObserver"/>
    </event>

    <event name="backend_block_widget_grid_prepare_grid_before">
        <observer name="mstSortingAddPinToTopColumn" instance="Mirasvit\Sorting\Observer\AddPinToTopColumnObserver"/>
    </event>
</config>
