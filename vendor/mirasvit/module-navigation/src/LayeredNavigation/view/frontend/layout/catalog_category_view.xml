<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="after.body.start">
            <block class="Mirasvit\LayeredNavigation\Block\ApplyButton" name="apply_button" template="Mirasvit_LayeredNavigation::applyButton.phtml"/>
        </referenceContainer>

        <referenceContainer name="head.additional">
            <block class="Mirasvit\LayeredNavigation\Block\Css" name="mst-nav.css"/>
        </referenceContainer>

        <referenceContainer name="sidebar.main">
            <block class="Mirasvit\LayeredNavigation\Block\Navigation\FilterExpander\Category" name="mst-nav.filterExpander"/>
            <block class="Mirasvit\LayeredNavigation\Block\StickySidebar" name="mst-nav.sidebarSticky" template="Mirasvit_LayeredNavigation::sticky.phtml" before="-"/>
        </referenceContainer>

        <referenceContainer name="content">
            <block class="Mirasvit\LayeredNavigation\Block\Ajax" name="category_ajax" template="Mirasvit_LayeredNavigation::ajax.phtml"/>
        </referenceContainer>
    </body>
</page>
