<?php

/** @var \Mirasvit\CatalogLabel\Block\Product\Label\Renderer $block */

$placeholders = $block->getPlaceholders();

if (!$placeholders || !$block->getProduct()) {
    return '';
}

foreach ($placeholders as $placeholder) {
    echo $block->getPlaceholderHtml($placeholder);
}

?>
