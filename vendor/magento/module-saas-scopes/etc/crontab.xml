<config
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="saas_data_exporter">
        <job
            name="submit_scopes_website_feed"
            instance="Magento\SaaSScopes\Cron\ScopesWebsiteSubmitFeed"
            method="execute">
            <schedule>* * * * *</schedule>
        </job>
        <job
            name="submit_scopes_customergroup_feed"
            instance="Magento\SaaSScopes\Cron\ScopesCustomerGroupSubmitFeed"
            method="execute">
            <schedule>* * * * *</schedule>
        </job>
    </group>
</config>
