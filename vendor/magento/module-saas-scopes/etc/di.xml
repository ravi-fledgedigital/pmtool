<config
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!--  Feed Registries -->
    <virtualType
        name="Magento\SaaSScopes\Model\ScopesWebsiteFeedRegistry"
        type="Magento\SaaSScopes\Model\ScopesFeedRegistry">
        <arguments>
            <argument name="excludeFields" xsi:type="array">
                <item name="modifiedAt" xsi:type="string">modifiedAt</item>
                <item name="updatedAt" xsi:type="string">updatedAt</item>
            </argument>
            <argument name="uniqueFields" xsi:type="array">
                <item name="websiteId" xsi:type="string">websiteId</item>
            </argument>
            <argument name="registryTable" xsi:type="string">scopes_website_data_submitted_hash</argument>
            <argument name="feedDataWrapper" xsi:type="string">website</argument>
        </arguments>
    </virtualType>

    <virtualType
        name="Magento\SaaSScopes\Model\ScopesCustomerGroupFeedRegistry"
        type="Magento\SaaSScopes\Model\ScopesFeedRegistry">
        <arguments>
            <argument name="excludeFields" xsi:type="array">
                <item name="modifiedAt" xsi:type="string">modifiedAt</item>
                <item name="updatedAt" xsi:type="string">updatedAt</item>
            </argument>
            <argument name="uniqueFields" xsi:type="array">
                <item name="customerGroupId" xsi:type="string">customerGroupId</item>
            </argument>
            <argument name="registryTable" xsi:type="string">scopes_customergroup_data_submitted_hash</argument>
            <argument name="feedDataWrapper" xsi:type="string">customerGroup</argument>
        </arguments>
    </virtualType>

    <!-- Feed Submitters -->
    <virtualType
        name="Magento\SaaSScopes\Cron\ScopesCustomerGroupSubmitFeed"
        type="Magento\SaaSCommon\Cron\SubmitFeed">
        <arguments>
            <argument name="feedMetadata" xsi:type="object">Magento\ScopesDataExporter\Model\Indexer\ScopesCustomerGroupFeedIndexMetadata</argument>
            <argument name="feedSyncFlag" xsi:type="string">scopes-customergroup-feed-version</argument>
            <argument name="feedRegistry" xsi:type="object">Magento\SaaSScopes\Model\ScopesCustomerGroupFeedRegistry</argument>
        </arguments>
    </virtualType>

    <virtualType
        name="Magento\SaaSScopes\Cron\ScopesWebsiteSubmitFeed"
        type="Magento\SaaSCommon\Cron\SubmitFeed">
        <arguments>
            <argument name="feedMetadata" xsi:type="object">Magento\ScopesDataExporter\Model\Indexer\ScopesWebsiteFeedIndexMetadata</argument>
            <argument name="feedSyncFlag" xsi:type="string">scopes-website-feed-version</argument>
            <argument name="feedRegistry" xsi:type="object">Magento\SaaSScopes\Model\ScopesWebsiteFeedRegistry</argument>
        </arguments>
    </virtualType>

    <!-- Resync Managers -->
    <virtualType
        name="Magento\SaaSScopes\Model\ScopesCustomerGroupRsyncManager"
        type="Magento\SaaSCommon\Model\ResyncManager">
        <arguments>
            <argument name="feedIndexer" xsi:type="object">Magento\ScopesDataExporter\Model\Indexer\ScopesCustomerGroupFeedIndexer</argument>
            <argument name="submitFeed" xsi:type="object">Magento\SaaSScopes\Cron\ScopesCustomerGroupSubmitFeed</argument>
            <argument name="feedInterface" xsi:type="object">Magento\ScopesDataExporter\Model\ScopesCustomerGroupFeed</argument>
            <argument name="flagName" xsi:type="string">scopes-customergroup-feed-version</argument>
            <argument name="indexerName" xsi:type="string">scopes_customergroup_data_exporter</argument>
            <argument name="registryTableName" xsi:type="string">scopes_customergroup_data_submitted_hash</argument>
        </arguments>
    </virtualType>

    <virtualType
        name="Magento\SaaSScopes\Model\ScopesWebsiteRsyncManager"
        type="Magento\SaaSCommon\Model\ResyncManager">
        <arguments>
            <argument name="feedIndexer" xsi:type="object">Magento\ScopesDataExporter\Model\Indexer\ScopesWebsiteFeedIndexer</argument>
            <argument name="submitFeed" xsi:type="object">Magento\SaaSScopes\Cron\ScopesWebsiteSubmitFeed</argument>
            <argument name="feedInterface" xsi:type="object">Magento\ScopesDataExporter\Model\ScopesWebsiteFeed</argument>
            <argument name="flagName" xsi:type="string">scopes-website-feed-version</argument>
            <argument name="indexerName" xsi:type="string">scopes_website_data_exporter</argument>
            <argument name="registryTableName" xsi:type="string">scopes_website_data_submitted_hash</argument>
        </arguments>
    </virtualType>

    <!--  Rsync registration -->
    <type name="Magento\SaaSCommon\Model\ResyncManagerPool">
        <arguments>
            <argument name="classMap" xsi:type="array">
                <item name="scopesWebsite" xsi:type="string">Magento\SaaSScopes\Model\ScopesWebsiteRsyncManager</item>
                <item name="scopesCustomerGroup" xsi:type="string">Magento\SaaSScopes\Model\ScopesCustomerGroupRsyncManager</item>
            </argument>
        </arguments>
    </type>
</config>
