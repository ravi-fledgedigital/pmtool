{
    "name": "magento/module-application-server",
    "description": "A module that implements Application Server on Swoole",
    "type": "magento2-module",
    "license": [
        "proprietary"
    ],
    "config": {
        "sort-packages": true
    },
    "version": "100.4.0",
    "require": {
        "php": "~8.1.0||~8.2.0||~8.3.0",
        "magento/framework": "103.0.*",
        "magento/module-catalog": "104.0.*",
        "magento/module-eav": "102.1.*"
    },
    "suggest": {
        "ext-swoole": "*",
        "ext-openswoole": "*"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Magento\\ApplicationServer\\": ""
        }
    }
}

