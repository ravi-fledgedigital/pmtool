use Magento\Framework\Escaper;
use Magento\CommerceBackendUix\Block\Adminhtml\System\Config\RefreshRegistrationsButton;

/**
 * @var Escaper $escaper
 * @var RefreshRegistrationsButton $block
 */

?>
<script>
    require([
        'jquery'
    ], function ($) {
        $('#refresh_registrations').click(function() {
            const failureMessage = "Failed to refresh registrations.";

            $.ajax({
                url: '<?= $escaper->escapeUrl($block->getAjaxUrl()) ?>',
                type: "GET",
                dataType: "json",
                success: function (result) {
                    if (result.status === 200) {
                        window.location.reload();
                    } else {
                        $('#message .message-text').text(failureMessage);
                        $('#message').addClass('message message-error error').show();
                    }
                },
                error: function () {
                    $('#message .message-text').text(failureMessage);
                    $('#message').addClass('message message-error error').show();
                }
            });
        });
    });
</script>

<?= $block->getButtonHtml() ?>

<div id="button-info">
    <div id="message" style="display: none;">
        <div class="message-text"></div>
    </div>
</div>
