/**
 * @var Magento\Backend\Block\Template $block
 * @var Magento\CommerceBackendUix\ViewModel\Config $viewModel
 * @var Magento\Framework\Escaper $escaper
 */
$viewModel = $block->getViewModel();
$config = $viewModel->getConfigPath();
$config = empty($config) ? '{}' : json_encode($config);
$cssFile = 'Magento_CommerceBackendUix::css/backend-uix-stylesheet.css';
if ($block->getAuthorization()->isAllowed('Magento_CommerceBackendUix::admin')) {
    ?>
    <link href="<?= /* @noEscape */ $block->getViewFileUrl($cssFile) ?>" rel="stylesheet" type="text/css" />
    <script src="<?= /* @noEscape */ $block->getViewFileUrl('Magento_CommerceBackendUix::js/backend-uix.js') ?>"
        commerce-config="<?= $escaper->escapeHtml($config) ?>"
        selected-ids=<?= /* @noEscape */ $viewModel->getSelectedIdsAsJson() ?>>
    </script>
<?php } ?>
