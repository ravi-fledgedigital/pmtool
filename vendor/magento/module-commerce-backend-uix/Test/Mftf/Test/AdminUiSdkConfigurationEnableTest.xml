<tests xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="urn:magento:mftf:Test/etc/testSchema.xsd">
    <test name="AdminUiSdkConfigurationEnableTest">
        <annotations>
            <features value="CommerceAdminUiSdk"/>
            <stories value="Login on the Admin Login page and enable Admin UI SDK"/>
            <title value="Admin should be able to log into the Admin panel and enable Admin UI SDK successfully"/>
            <description value="Admin should be able to log into the Admin panel and enable Admin UI SDK successfully"/>
            <severity value="CRITICAL"/>
            <testCaseId value="admin-ui-sdk-config-enable"/>
            <group value="admin-ui-sdk"/>
        </annotations>

        <actionGroup ref="AdminLoginActionGroup" stepKey="loginAsAdmin"/>
        <actionGroup ref="AdminEnableAdminUiSdkActionGroup" stepKey="enableAdminUiSdk"/>
        <actionGroup ref="AdminLogoutActionGroup" stepKey="logoutFromAdmin"/>

    </test>
</tests>
