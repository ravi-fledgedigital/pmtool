<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <!--  Product Feed  -->
    <virtualType name="Magento\SaaSPrice\Cron\PriceSubmitFeed" type="Magento\SaaSCommon\Cron\SubmitFeed">
        <arguments>
            <argument name="feedMetadata" xsi:type="object">Magento\ProductPriceDataExporter\Model\Indexer\ProductPriceFeedIndexMetadata</argument>
            <argument name="feedSyncFlag" xsi:type="string">price-feed-version</argument>
        </arguments>
    </virtualType>
    <virtualType name="Magento\SaaSPrice\Model\PriceResyncManager" type="Magento\SaaSCommon\Model\ResyncManager">
        <arguments>
            <argument name="feedIndexer" xsi:type="object">Magento\ProductPriceDataExporter\Model\Indexer\ProductPriceFeedIndexer</argument>
            <argument name="submitFeed" xsi:type="object">Magento\SaaSPrice\Cron\PriceSubmitFeed</argument>
            <argument name="feedInterface" xsi:type="object">Magento\ProductPriceDataExporter\Model\ProductPriceFeed</argument>
            <argument name="flagName" xsi:type="string">price-feed-version</argument>
            <argument name="indexerName" xsi:type="string">catalog_data_exporter_product_prices</argument>
            <argument name="registryTableName" xsi:type="string">price_data_submitted_hash</argument>
        </arguments>
    </virtualType>

    <!--  Resync registration  -->
    <type name="Magento\SaaSCommon\Model\ResyncManagerPool">
        <arguments>
            <argument name="classMap" xsi:type="array">
                <item name="prices" xsi:type="string">Magento\SaaSPrice\Model\PriceResyncManager</item>
            </argument>
        </arguments>
    </type>

    <type name="Magento\SaaSCommon\Model\DataFilter">
        <arguments>
            <argument name="reservedFields" xsi:type="array">
                <item name="prices" xsi:type="array">
                    <item name="product_id" xsi:type="string">product_id</item>
                    <item name="customer_group_code" xsi:type="string">customer_group_code</item>
                    <item name="website_id" xsi:type="string">website_id</item>
                </item>
            </argument>
        </arguments>
    </type>
</config>
