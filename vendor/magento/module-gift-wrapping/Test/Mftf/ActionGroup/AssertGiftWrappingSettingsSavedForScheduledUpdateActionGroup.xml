<actionGroups xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:noNamespaceSchemaLocation="urn:magento:mftf:Test/etc/actionGroupSchema.xsd">
    <actionGroup name="AssertGiftWrappingSettingsSavedForScheduledUpdateActionGroup">
        <annotations>
            <description>Assert that gift wrapping setting are saved for a product after scheduled update</description>
        </annotations>
        <arguments>
            <argument name="allowGiftWrap" type="string"/>
        </arguments>
        <conditionalClick selector="{{AdminProductGridSection.productCollapsibleColumnsScheduleUpdate('closed','Gift Options')}}" dependentSelector="{{AdminProductGridSection.productCollapsibleColumnsScheduleUpdate('closed','Gift Options')}}" visible="true" stepKey="expandGiftOptions"/>
        <scrollTo selector="{{AdminProductGridSection.allowGiftsWrapCheckbox}}" x="-200" y="-200" stepKey="scrollToUncheckUseConfigSettings"/>
        <dontSeeCheckboxIsChecked selector="{{AdminProductGridSection.allowGiftsWrapCheckbox}}" stepKey="seeUseConfigSettingsIsUnchecked"/>
        <dontSeeCheckboxIsChecked selector="{{AdminProductGridSection.allowGiftsWrapToggle(allowGiftWrap)}}" stepKey="seeAllowGiftWrappingSetToNo"/>
    </actionGroup>
</actionGroups>
