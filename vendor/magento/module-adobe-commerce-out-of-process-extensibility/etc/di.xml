<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <preference for="Magento\AdobeCommerceOutOfProcessExtensibility\Model\Converter\ClassToArrayConverterInterface" type="Magento\AdobeCommerceOutOfProcessExtensibility\Model\Converter\ClassToArrayConverter" />
    <preference for="Magento\AdobeCommerceOutOfProcessExtensibility\Model\Converter\EventCodeConverterInterface" type="Magento\AdobeCommerceOutOfProcessExtensibility\Model\Converter\EventCodeConverter" />
    <preference for="Magento\AdobeCommerceOutOfProcessExtensibility\Model\Collector\CollectorInterface" type="Magento\AdobeCommerceOutOfProcessExtensibility\Model\Collector\CompositeCollector" />
    <preference for="Magento\AdobeCommerceOutOfProcessExtensibility\Model\Collector\AggregatedEventListInterface" type="Magento\AdobeCommerceOutOfProcessExtensibility\Model\Collector\AggregatedEventList" />
    <preference for="Magento\AdobeCommerceOutOfProcessExtensibility\Model\Request\RequestIdInterface" type="Magento\AdobeCommerceOutOfProcessExtensibility\Model\Request\RequestId" />
    <type name="Magento\AdobeCommerceOutOfProcessExtensibility\Model\Collector\CompositeCollector">
        <arguments>
            <argument name="collectors" xsi:type="array">
                <item name="apiServiceCollector" xsi:type="object">Magento\AdobeCommerceOutOfProcessExtensibility\Model\Collector\ApiServiceCollector</item>
                <item name="resourceModelCollector" xsi:type="object">Magento\AdobeCommerceOutOfProcessExtensibility\Model\Collector\ResourceModelCollector</item>
                <item name="observerEventsCollector" xsi:type="object">Magento\AdobeCommerceOutOfProcessExtensibility\Model\Collector\ObserverEventsCollector</item>
            </argument>
        </arguments>
    </type>
    <type name="Magento\AdobeCommerceOutOfProcessExtensibility\Model\Collector\ObserverEventsCollector">
        <arguments>
            <argument name="filesystem" xsi:type="object">Magento\Framework\Filesystem\Driver\File</argument>
        </arguments>
    </type>
    <type name="Magento\AdobeCommerceOutOfProcessExtensibility\Model\Collector\ApiServiceCollector">
        <arguments>
            <argument name="filesystem" xsi:type="object">Magento\Framework\Filesystem\Driver\File</argument>
        </arguments>
    </type>
    <type name="Magento\AdobeCommerceOutOfProcessExtensibility\Model\Collector\ResourceModelCollector">
        <arguments>
            <argument name="filesystem" xsi:type="object">Magento\Framework\Filesystem\Driver\File</argument>
        </arguments>
    </type>
    <type name="Magento\AdobeCommerceOutOfProcessExtensibility\Model\Generator\ModuleGenerator">
        <arguments>
            <argument name="templateEngine" xsi:type="object">Magento\Framework\View\TemplateEngine\Php</argument>
        </arguments>
    </type>
    <type name="Magento\AdobeCommerceOutOfProcessExtensibility\Model\Context\ContextPool">
        <arguments>
            <argument name="contexts" xsi:type="array">
                <item name="context_checkout_session" xsi:type="string">Magento\Checkout\Model\Session</item>
                <item name="context_customer_session" xsi:type="string">Magento\Customer\Model\Session</item>
                <item name="context_registry" xsi:type="string">Magento\Framework\Registry</item>
                <item name="context_application_state" xsi:type="string">Magento\Framework\App\State</item>
                <item name="context_scope_config" xsi:type="string">Magento\Framework\App\Config\ScopeConfigInterface</item>
                <item name="context_http_request" xsi:type="string">Magento\Framework\App\Request\Http</item>
                <item name="context_staging" xsi:type="string">Magento\Staging\Model\VersionManager</item>
                <item name="context_store" xsi:type="string">Magento\Store\Model\StoreManagerInterface</item>
            </argument>
        </arguments>
    </type>
</config>
