<actionGroups xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:mftf:Test/etc/actionGroupSchema.xsd">
    <actionGroup name="AdminVerifyEnvironmentInfoMySQLStatusActionGroup">
        <annotations>
            <description>Admin verify Environment information and MySQL status is present in the created environment system report</description>
        </annotations>
        <waitForText selector="{{SystemReportSection.verifyText}}" userInput="Environment Information" stepKey="systemReportContainsEnvironmentInformation"/>
        <waitForText selector="{{SystemReportSection.verifyText}}" userInput="MySQL Status" stepKey="systemReportContainsMySQLStatus"/>
    </actionGroup>
</actionGroups>
