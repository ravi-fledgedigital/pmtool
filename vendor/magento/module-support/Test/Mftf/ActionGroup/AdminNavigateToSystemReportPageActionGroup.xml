<actionGroups xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:mftf:Test/etc/actionGroupSchema.xsd">
    <actionGroup name="AdminNavigateToSystemReportPageActionGroup">
        <annotations>
            <description>Admin navigates to System Report Page</description>
        </annotations>
        <amOnPage url="{{SystemReportPage.url}}" stepKey="adminNavigateToSystemReport" />
        <waitForPageLoad stepKey="waitForPageLoadToViewSystemReportPage"/>
    </actionGroup>
</actionGroups>
