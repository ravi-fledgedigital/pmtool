<actionGroups xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:mftf:Test/etc/actionGroupSchema.xsd">
    <actionGroup name="AdminVerifyCreatedReportPresentInSystemReportGridActionGroup">
        <annotations>
            <description>Admin verifies created report is present inside the system report grid</description>
        </annotations>
        <arguments>
            <argument name="reportNameInGrid" type="string"/>
        </arguments>
        <waitForText selector="{{SystemReportSection.createdReportInGrid}}" userInput="{{reportNameInGrid}}" stepKey="adminVerifyCreatedSystemReportIsInTheSystemReportGrid"/>
    </actionGroup>
</actionGroups>
