<?xml version="1.0" encoding="UTF-8"?>

<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="http://schema.phpunit.de/10.5/phpunit.xsd"
         colors="true"
         columns="max"
         bootstrap="../../autoload.php"
>
    <testsuites>
        <testsuite name="Unit">
            <directory suffix="Test.php">../../src/Test/Unit</directory>
        </testsuite>
        <testsuite name="Integrity">
            <directory suffix="Test.php">../../src/Test/Integrity/Testsuite</directory>
        </testsuite>
    </testsuites>
     <source>
        <include>
            <directory>../../src</directory>
        </include>
    </source>
    
    <php>
        <ini name="date.timezone" value="UTC"/>
    </php>
</phpunit>
