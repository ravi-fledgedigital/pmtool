<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Magento_AdobeCommerceEventsClient::menu" title="Eventing Framework" translate="title" sortOrder="120">
                    <resource id="Magento_AdobeCommerceEventsClient::event_list" title="Event List" translate="title" sortOrder="10" />
                    <resource id="Magento_AdobeCommerceEventsClient::test_connection" title="Test Eventing Connection" translate="title" sortOrder="20" />
                    <resource id="Magento_AdobeCommerceEventsClient::event_subscribe" title="Subscribe to an event" translate="title" sortOrder="30" />
                    <resource id="Magento_AdobeCommerceEventsClient::event_unsubscribe" title="Unsubscribe from an event" translate="title" sortOrder="40" />
                    <resource id="Magento_AdobeCommerceEventsClient::event_status" title="Event Status" translate="title" sortOrder="50" />
                    <resource id="Magento_AdobeCommerceEventsClient::event_subscriptions" title="API to get event subscriptions" translate="title" sortOrder="60" />
                    <resource id="Magento_AdobeCommerceEventsClient::event_provider" title="Event Providers page" translate="title" sortOrder="70" />
                </resource>
                <resource id="Magento_AdobeIoEventsClient::configuration">
                    <resource id="Magento_AdobeIoEventsClient::configuration_update" title="Configuration Update"
                              translate="title" sortOrder="20" />
                    <resource id="Magento_AdobeIoEventsClient::synchronize_events" title="Synchronize Events"
                              translate="title" sortOrder="30" />
                    <resource id="Magento_AdobeIoEventsClient::event_provider_list" title="Get Event Provider List"
                              translate="title" sortOrder="40" />
                    <resource id="Magento_AdobeIoEventsClient::event_provider_edit" title="Edit Event Provider"
                              translate="title" sortOrder="50" />
                    <resource id="Magento_AdobeIoEventsClient::event_provider_delete" title="Delete Event Provider"
                              translate="title" sortOrder="60" />
                </resource>
            </resource>
        </resources>
    </acl>
</config>
