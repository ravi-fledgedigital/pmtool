<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <adobe_io_events>
            <eventing>
                <enabled>0</enabled>
                <max_retries>7</max_retries>
                <event_retention>3</event_retention>
                <max_event_data_size>65536</max_event_data_size>
            </eventing>
            <integration>
                <adobe_io_event_provider_metadata>dx_commerce_events</adobe_io_event_provider_metadata>
                <endpoint_production>https://commerce-eventing.adobe.io</endpoint_production>
                <endpoint_stage>https://commerce-eventing-stage.adobe.io</endpoint_stage>
                <endpoint_dev>https://commerce-eventing-dev.adobe.io</endpoint_dev>
            </integration>
        </adobe_io_events>
    </default>
</config>
