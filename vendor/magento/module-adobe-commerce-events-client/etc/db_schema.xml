<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="event_data" resource="default" engine="innodb" comment="Event Data">
        <column xsi:type="int" name="event_id" unsigned="true" nullable="false" identity="true"
                comment="Event ID"/>
        <column xsi:type="varchar" name="event_track_id" nullable="false" length="128"
                comment="Event Track ID"/>
        <column xsi:type="varchar" name="event_code" nullable="false" length="128"
                comment="Event code"/>
        <column xsi:type="text" name="event_data" nullable="false"
                comment="Event data"/>
        <column xsi:type="text" name="metadata" nullable="false" comment="Metadata to send to the pipeline"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Updated At"/>
        <column xsi:type="int" name="retries_count" unsigned="true" nullable="false" default="0"
                comment="Retry count for sending event data"/>
        <column xsi:type="tinyint" name="status" unsigned="true" nullable="false" default="0"
                comment="Status of sending event data"/>
        <column xsi:type="text" name="info" nullable="false" comment="Additional information about event status"/>
        <column xsi:type="tinyint" name="priority" unsigned="true" nullable="false" default="0"
                comment="Priority of sending event data"/>
        <column xsi:type="tinyint" name="hipaa_audit_required" unsigned="true" nullable="false" default="0"
                comment="Flag for events that contain data that is subject to HIPAA auditing"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="event_id"/>
        </constraint>
        <index referenceId="EVENT_DATA_STATUS" indexType="btree">
            <column name="status"/>
        </index>
    </table>
    <table name="event_provider" resource="default" engine="innodb" comment="Event Providers">
        <column xsi:type="int" name="id" unsigned="true" nullable="false" identity="true"
                comment="ID"/>
        <column xsi:type="varchar" name="provider_id" nullable="false" length="128"
                comment="Provider Id"/>
        <column xsi:type="varchar" name="instance_id" nullable="false" length="128"
                comment="Instance Id"/>
        <column xsi:type="varchar" name="label" nullable="true" length="255"
                comment="Label"/>
        <column xsi:type="text" name="description" nullable="true"
                comment="Description"/>
        <column xsi:type="text" name="workspace_configuration" nullable="true"
                comment="Workspace configuration"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>
        <constraint referenceId="unique_provider_id"  xsi:type="unique">
            <column name="provider_id"/>
        </constraint>
    </table>
</schema>
