use Magento\Framework\Escaper;
use Magento\AdobeCommerceEventsClient\Block\Adminhtml\System\Config\SynchronizeEventsButton;

/** @var Escaper $escaper */
/** @var SynchronizeEventsButton $block */
?>
<script type="text/x-magento-init">
    {
        "#synchronize_events": {
            "Magento_AdobeCommerceEventsClient/js/configuration-button": {
                "ajaxUrl": "<?= $escaper->escapeUrl($block->getAjaxUrl()) ?>",
                "buttonId": "#synchronize_events",
                "buttonInfoId": "#synchronize_button_info",
                "messageDivId": "#synchronization_message",
                "messages": {
                    "saveConfig": "Save your configuration before synchronizing events.",
                    "success": "Successfully synchronized events.",
                    "failure": "Failed to synchronize events."
                }
            }
        }
    }
</script>

<?= $block->getButtonHtml() ?>
<div id="synchronize_button_info">
<?php if (!$block->isConfigurationComplete()): ?>
    <p class="note">
        <span>Complete all fields in the "General configuration" section before synchronizing events.</span>
    </p>
<?php elseif (!$block->hasEventsToSync()): ?>
    <p class="note"><span>No events for syncing to Adobe I/O found.</span></p>
<?php else: ?>
    <div id="synchronization_message" style="display: none;">
        <div class="message-text"></div>
    </div>
<?php endif; ?>
</div>
