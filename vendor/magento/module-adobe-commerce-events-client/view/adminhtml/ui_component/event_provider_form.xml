<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">event_provider_form.event_provider_form_data_source</item>
        </item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <label translate="true">Event Provider Information</label>
        <dataScope>data</dataScope>
        <namespace>event_provider_form</namespace>
        <deps>
            <dep>event_provider_form.event_provider_form_data_source</dep>
        </deps>
        <buttons>
            <button name="back">
                <url path="*/*/index"/>
                <class>back</class>
                <label translate="true">Back</label>
            </button>
            <button name="reset">
                <class>reset</class>
                <label translate="true">Reset</label>
            </button>
            <button name="save" class="Magento\AdobeCommerceEventsClient\Block\Adminhtml\EventProvider\Edit\SaveButton" />
        </buttons>
    </settings>
    <dataSource name="event_provider_form_data_source" component="Magento_Ui/js/form/provider">
        <settings>
            <submitUrl path="*/*/save"/>
        </settings>
        <dataProvider class="Magento\AdobeCommerceEventsClient\Ui\DataProvider\EventProviderDataProvider" name="event_provider_form_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <fieldset name="general" sortOrder="10">
        <settings>
            <label translate="true">Event Provider configuration</label>
            <collapsible>false</collapsible>
            <opened>true</opened>
            <dataScope>general</dataScope>
        </settings>
        <field name="provider_id" formElement="input" sortOrder="10">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Provider ID</label>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="instance_id" formElement="input" sortOrder="20">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Instance ID</label>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="label" formElement="input" sortOrder="30">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Label</label>
            </settings>
        </field>
        <field name="description" formElement="input" sortOrder="40">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Description</label>
            </settings>
        </field>
        <field name="workspace_configuration" formElement="textarea" sortOrder="50">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Workspace Configuration</label>
                <notice>Configuration of the workspace associated with this event provider. If not provided the Event Metadata won't be created automatically.</notice>
            </settings>
        </field>
    </fieldset>
</form>
