<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">event_provider_grid.event_provider_grid_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>event_provider_columns</spinner>
        <deps>
            <dep>event_provider_grid.event_provider_grid_data_source</dep>
        </deps>
        <buttons>
            <button name="add">
                <url path="*/*/new"/>
                <class>primary</class>
                <label translate="true">Add New Provider</label>
            </button>
        </buttons>
    </settings>
    <dataSource name="event_provider_grid_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/grid/provider</item>
            </item>
        </argument>
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Magento_AdobeCommerceEventsClient::event_provider</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider"
                      name="event_provider_grid_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <columnsControls name="columns_controls" />
        <filters name="listing_filters" />
        <paging name="listing_paging" />
    </listingToolbar>
    <columns name="event_provider_columns">
        <column name="id" sortOrder="10">
            <settings>
                <filter>text</filter>
                <bodyTmpl>ui/grid/cells/text</bodyTmpl>
                <label translate="true">ID</label>
                <sortable>true</sortable>
                <sorting>desc</sorting>
            </settings>
        </column>
        <column name="provider_id" sortOrder="20">
            <settings>
                <filter>text</filter>
                <bodyTmpl>ui/grid/cells/text</bodyTmpl>
                <label translate="true">Provider ID</label>
                <sortable>false</sortable>
            </settings>
        </column>
        <column name="instance_id" sortOrder="30">
            <settings>
                <filter>text</filter>
                <bodyTmpl>ui/grid/cells/text</bodyTmpl>
                <label translate="true">Instance ID</label>
                <sortable>false</sortable>
            </settings>
        </column>
        <column name="label" sortOrder="40">
            <settings>
                <filter>text</filter>
                <bodyTmpl>ui/grid/cells/text</bodyTmpl>
                <label translate="true">Label</label>
                <sortable>false</sortable>
            </settings>
        </column>
        <column name="description" sortOrder="50">
            <settings>
                <filter>text</filter>
                <bodyTmpl>ui/grid/cells/text</bodyTmpl>
                <label translate="true">Description</label>
                <sortable>false</sortable>
            </settings>
        </column>
        <actionsColumn name="actions" class="Magento\AdobeCommerceEventsClient\Ui\Component\Listing\EventProvider\Column\EventProviderActions" sortOrder="200">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="editUrlPath" xsi:type="string">adminhtml/eventprovider/edit</item>
                    <item name="deleteUrlPath" xsi:type="string">adminhtml/eventprovider/delete</item>
                </item>
            </argument>
            <settings>
                <indexField>id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>
