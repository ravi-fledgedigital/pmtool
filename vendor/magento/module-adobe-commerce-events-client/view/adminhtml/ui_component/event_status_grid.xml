<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">event_status_grid.event_status_grid_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>event_status_columns</spinner>
        <deps>
            <dep>event_status_grid.event_status_grid_data_source</dep>
        </deps>
    </settings>
    <dataSource name="event_status_grid_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/grid/provider</item>
            </item>
        </argument>
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">event_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Magento_AdobeCommerceEventsClient::event_status</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider"
                      name="event_status_grid_data_source">
            <settings>
                <requestFieldName>event_id</requestFieldName>
                <primaryFieldName>event_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <columnsControls name="columns_controls" />
        <filters name="listing_filters" />
        <paging name="listing_paging" />
    </listingToolbar>
    <columns name="event_status_columns">
        <column name="event_id" sortOrder="10">
            <settings>
                <filter>textRange</filter>
                <bodyTmpl>ui/grid/cells/text</bodyTmpl>
                <label translate="true">Event ID</label>
                <sortable>true</sortable>
                <sorting>desc</sorting>
            </settings>
        </column>
        <column name="event_code" sortOrder="20">
            <settings>
                <filter>text</filter>
                <bodyTmpl>ui/grid/cells/text</bodyTmpl>
                <label translate="true">Event Code</label>
                <sortable>false</sortable>
            </settings>
        </column>
        <column name="created_at" sortOrder="30">
            <settings>
                <filter>dateRange</filter>
                <bodyTmpl>ui/grid/cells/text</bodyTmpl>
                <label translate="true">Created At</label>
                <sortable>false</sortable>
            </settings>
        </column>
        <column name="updated_at" sortOrder="40">
            <settings>
                <filter>dateRange</filter>
                <bodyTmpl>ui/grid/cells/text</bodyTmpl>
                <label translate="true">Updated At</label>
                <sortable>false</sortable>
            </settings>
        </column>
        <column name="retries_count" sortOrder="50">
            <settings>
                <filter>text</filter>
                <bodyTmpl>ui/grid/cells/text</bodyTmpl>
                <label translate="true">Retries Count</label>
                <sortable>false</sortable>
            </settings>
        </column>
        <column name="status" sortOrder="60" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="Magento\AdobeCommerceEventsClient\Ui\Component\Listing\Status\StatusOptionSource"/>
                <filter>select</filter>
                <editor>
                    <editorType>select</editorType>
                </editor>
                <bodyTmpl>ui/grid/cells/text</bodyTmpl>
                <label translate="true">Status</label>
                <dataType>select</dataType>
                <sortable>false</sortable>
            </settings>
        </column>
        <column name="info" sortOrder="70">
            <settings>
                <filter>text</filter>
                <bodyTmpl>ui/grid/cells/text</bodyTmpl>
                <label translate="true">Info</label>
                <sortable>false</sortable>
            </settings>
        </column>
        <column name="priority" sortOrder="80" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="Magento\AdobeCommerceEventsClient\Ui\Component\Listing\Priority\PriorityOptionSource"/>
                <filter>select</filter>
                <editor>
                    <editorType>select</editorType>
                </editor>
                <bodyTmpl>ui/grid/cells/text</bodyTmpl>
                <label translate="true">Priority</label>
                <dataType>select</dataType>
                <sortable>false</sortable>
            </settings>
        </column>
    </columns>
</listing>
