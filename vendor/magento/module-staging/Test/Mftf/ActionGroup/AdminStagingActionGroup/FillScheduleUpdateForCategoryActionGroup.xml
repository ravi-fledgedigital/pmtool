<actionGroups xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:noNamespaceSchemaLocation="urn:magento:mftf:Test/etc/actionGroupSchema.xsd">
    <actionGroup name="FillScheduleUpdateForCategoryActionGroup" extends="AdminFillPermanentUpdateActionGroup">
        <annotations>
            <description>If necessary, click on the "Schedule New Update" button and fill in the data and category name for permanent update</description>
        </annotations>
        <arguments>
            <argument name="updateName" type="string"/>
        </arguments>
        <generateDate date="{{stage.startDate}}" timezone="America/Chicago" format="m/d/Y g:i A"  stepKey="generateStartDate"/>
        <waitForElementVisible selector="{{AdminStagingSlideOutSection.startDate}}" stepKey="waitForStartDateVisible"/>
        <fillField selector="{{AdminStagingSlideOutSection.startDate}}" userInput="{$generateStartDate}" stepKey="fillStartDate"/>
        <!-- Replacement action. The action will be performed only if necessary. -->
        <conditionalClick selector="{{AdminProductScheduleUpdateSection.scheduleNewUpdateBtn}}" dependentSelector="{{AdminStagingSlideOutSection.updateName}}" visible="false" stepKey="scheduleNewUpdateBtn"/>
        <!--Fill category update name-->
        <waitForElementVisible selector="{{AdminCatalogStagingSlideOutSection.categoryName}}" stepKey="waitForCategoryNameVisible"/>
        <fillField selector="{{AdminCatalogStagingSlideOutSection.categoryName}}" userInput="{{updateName}}" after="fillStartDate" stepKey="fillNewCategoryName"/>
    </actionGroup>
</actionGroups>
