<?php
/**
 * @var \Magento\Sales\Block\Adminhtml\Order\Create\Coupons $block
 * @var \Magento\Framework\Escaper $escaper
 * @var \Magento\Framework\View\Helper\SecureHtmlRenderer $secureRenderer
 */
$coupons = $block->getQuote()->getExtensionAttributes()->getCouponCodes() ?? [];
if ($block->getQuote()->getCouponCode() && !in_array($block->getQuote()->getCouponCode(), $coupons)) {
    array_unshift($coupons, $block->getQuote()->getCouponCode());
}
?>
<div class="admin__field field-apply-coupon-code">
    <label class="admin__field-label"><span><?= $escaper->escapeHtml(__('Apply Coupon Code')) ?></span></label>
    <div class="admin__field-control">
        <input type="text" class="admin__control-text" id="coupons:code" value="" name="coupon_code" />
            <?= $block->getButtonHtml(__('Apply'), 'order.handleOnclickCoupon($F(\'coupons:code\'))') ?>
        <?php foreach ($coupons as $code): ?>
            <p class="added-coupon-code coupon-code-<?= $escaper->escapeHtml($code) ?>">
                <span><?= $escaper->escapeHtml($code) ?></span>
                <a href="#" title="<?= $escaper->escapeHtmlAttr(__('Remove Coupon Code')) ?>"
                   class="action-remove"><span><?= $escaper->escapeHtml(__('Remove')) ?></span></a>
            </p>
            <?= /* @noEscape */ $secureRenderer->renderEventListenerAsTag(
                'onclick',
                "order.removeCoupon('$code');event.preventDefault();",
                'p.added-coupon-code.coupon-code-' . $code . ' a.action-remove'
            ) ?>
        <?php endforeach; ?>
        <?php $isVirtual = ($block->getQuote()->isVirtual() ? 'false' : 'true');
        $scriptString = <<<script
            require([
                "jquery",
                'Magento_Ui/js/modal/alert',
                'mage/translate',
                "Magento_Sales/order/create/form"
            ], function($, alert) {
                order.overlay('shipping-method-overlay', {$isVirtual});
                order.overlay('address-shipping-overlay', {$isVirtual});
                order.handleOnclickCoupon = function (code) {
                    if (!code) {
                        alert({
                            content: $.mage.__('Please enter a coupon code!')
                        });
                    } else {
                        order.applyCoupon(code);
                    }
                };
            });
script;
        ?>
        <?= /* @noEscape */ $secureRenderer->renderTag('script', [], $scriptString, false) ?>
    </div>
</div>
