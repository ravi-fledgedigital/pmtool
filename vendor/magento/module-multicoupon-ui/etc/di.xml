<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Magento\Sales\Model\AdminOrder\Create">
        <plugin name="couponsAfterImportPostData" type="Magento\MulticouponUi\Plugin\AdminCreateOrderApplyCoupons"/>
    </type>
    <type name="Magento\Sales\Model\Order\Create\ValidateCoupon">
        <plugin name="orderCreateCouponsValidation" type="Magento\MulticouponUi\Plugin\AdminCreateOrderValidateCoupon"/>
    </type>
    <type name="Magento\AdvancedCheckout\Model\ApplyCoupons">
        <plugin name="manageCartApplyCoupons" type="Magento\MulticouponUi\Plugin\AdminCartApplyCoupons"/>
    </type>
</config>
