<?php
/** @var \Magento\DataServices\Block\Context $block */
/** @var \Magento\DataServices\ViewModel\WishListProvider $viewModel */
/** @var \Magento\Framework\View\Helper\SecureHtmlRenderer $secureRenderer */
$viewModel = $block->getViewModel();
$userAction = $viewModel->getUserAction();
$pageAction = $userAction ? $userAction : $block->getData('step_name');
?>

<?php
$scriptString = <<<script
    require(['magentoStorefrontEvents'], function (magentoStorefrontEvents) {
        if(!magentoStorefrontEvents) return;
        
        magentoStorefrontEvents.context.setPage({
            pageType: "{$block->getData('page_type')}"
        });
        magentoStorefrontEvents.context.setContext("pageExtended", {
            action: "{$block->getData('step_name')}"
        });
        magentoStorefrontEvents.context.setShoppingCart({
            id: {$block->getCartId()}
        });
    });
script;
?>
<?= /* @noEscape */ $secureRenderer->renderTag('script', [], $scriptString, false) ?>
