<?php
/** @var \Magento\DataServices\Block\Context $block */
/** @var \Magento\Framework\View\Helper\SecureHtmlRenderer $secureRenderer */
?>
<?php
    $accountContextScript = <<<script
    let accountContext = magentoStorefrontEvents.context.getAccount() || {};
    accountContext.emailAddress = "{$block->getCustomerEmail()}";
    magentoStorefrontEvents.context.setAccount(accountContext);
    script;
    $showAccountContext = ($block->getCustomerEmail() !== null) ? $accountContextScript : '';

    $scriptString = <<<script
    require(['magentoStorefrontEvents'], function (magentoStorefrontEvents) {
        if(!magentoStorefrontEvents) return;

        window.magentoStorefrontEvents = magentoStorefrontEvents;
        magentoStorefrontEvents.context.setStorefrontInstance(
            {$block->getStorefrontInstanceContext()}
        );
        magentoStorefrontEvents.context.setMagentoExtension({
            magentoExtensionVersion: "{$block->getExtensionVersion()}",
        });
        magentoStorefrontEvents.context.setDataServicesExtension({
            version: "{$block->getExtensionVersion()}",
        });
        magentoStorefrontEvents.context.setPage({
            pageType: "{$block->getData('page_type')}"
        });
        magentoStorefrontEvents.context.setContext("pageExtended", {
            action: "{$block->getData('step_name')}"
        });
        {$showAccountContext}
    });
    script;
?>
<?= /* @noEscape */ $secureRenderer->renderTag('script', [], $scriptString, false) ?>
<script type="text/x-magento-init">
    {
        "*": {
            "dataServicesBase": {
                "isCookieRestrictionModeEnabled": <?= (int) $block->isCookieRestrictionModeEnabled() ?>,
                "isEnabled": <?= (int) $block->isEnabled() ?>
            },
            "magentoStorefrontEventCollector": {}
        }
    }
</script>
