<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Magento\Framework\Console\CommandListInterface">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="webhookModuleGenerateCommand" xsi:type="object">
                    Magento\AdobeCommerceWebhooksGenerator\Console\Command\GenerateModuleCommand
                </item>
            </argument>
        </arguments>
    </type>
    <type name="Magento\AdobeCommerceWebhooksGenerator\Model\Generator\WebhooksClassGenerator">
        <arguments>
            <argument name="templateEngine" xsi:type="object">Magento\Framework\View\TemplateEngine\Php</argument>
        </arguments>
    </type>
    <virtualType name="webhookModuleGenerator" type="Magento\AdobeCommerceOutOfProcessExtensibility\Model\Generator\ModuleGenerator">
        <arguments>
            <argument name="classGenerator" xsi:type="object">Magento\AdobeCommerceWebhooksGenerator\Model\Generator\WebhooksClassGenerator</argument>
        </arguments>
    </virtualType>
    <type name="Magento\AdobeCommerceWebhooksGenerator\Console\Command\GenerateModule\Generator">
        <arguments>
            <argument name="moduleGenerator" xsi:type="object">webhookModuleGenerator</argument>
        </arguments>
    </type>
</config>
