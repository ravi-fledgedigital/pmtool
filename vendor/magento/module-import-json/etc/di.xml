<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <preference for="Magento\ImportJsonApi\Api\StartImportInterface"
                type="Magento\ImportJson\Model\StartImport"/>
    <preference for="Magento\ImportJsonApi\Api\Data\SourceDataInterface"
                type="Magento\ImportJson\Model\SourceData"/>
    <preference for="Magento\CatalogImportExport\Model\Import\Product\CategoryProcessor"
                type="Magento\ImportJson\Model\StructuredCategoryProcessor"/>

    <type name="Magento\CatalogImportExport\Model\Import\Product">
        <plugin name="parse_multiselect_structured_values"
                type="Magento\ImportJson\Plugin\StructuredMultiSelectAttributeHandler"/>
    </type>
    <type name="Magento\ImportExport\Model\Import\EntityInterface">
        <plugin name="no_need_to_login_import_history_for_import_json"
                type="Magento\ImportJson\Plugin\NoNeedToLoginImportHistory" sortOrder="100"/>
    </type>
</config>
