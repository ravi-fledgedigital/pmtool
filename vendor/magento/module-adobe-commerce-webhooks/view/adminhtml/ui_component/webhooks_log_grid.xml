<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">webhooks_log_grid.webhooks_log_grid_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>webhooks_log_columns</spinner>
        <deps>
            <dep>webhooks_log_grid.webhooks_log_grid_data_source</dep>
        </deps>
    </settings>
    <dataSource name="webhooks_log_grid_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/grid/provider</item>
            </item>
        </argument>
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
            <filterUrlParams>
                <param name="webhook_method">*</param>
                <param name="webhook_type">*</param>
                <param name="batch_name">*</param>
                <param name="hook_name">*</param>
            </filterUrlParams>
        </settings>
        <aclResource>Magento_AdobeCommerceWebhooks::webhooks_log_grid</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider"
                      name="webhooks_log_grid_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <columnsControls name="columns_controls" />
        <filters name="listing_filters" component="Magento_AdobeCommerceWebhooks/js/grid/filters/logs-filter"/>
        <paging name="listing_paging" />
    </listingToolbar>
    <columns name="webhooks_log_columns">
        <column name="id" sortOrder="10">
            <settings>
                <filter>textRange</filter>
                <bodyTmpl>ui/grid/cells/text</bodyTmpl>
                <label translate="true">Log record id</label>
                <sortable>true</sortable>
                <sorting>desc</sorting>
            </settings>
        </column>
        <column name="webhook_method" sortOrder="20">
            <settings>
                <filter>text</filter>
                <bodyTmpl>ui/grid/cells/text</bodyTmpl>
                <label translate="true">Webhook Method</label>
                <sortable>false</sortable>
            </settings>
        </column>
        <column name="webhook_type" sortOrder="30">
            <settings>
                <filter>text</filter>
                <bodyTmpl>ui/grid/cells/text</bodyTmpl>
                <label translate="true">Webhook Type</label>
                <sortable>false</sortable>
            </settings>
        </column>
        <column name="batch_name" sortOrder="40">
            <settings>
                <filter>text</filter>
                <bodyTmpl>ui/grid/cells/text</bodyTmpl>
                <label translate="true">Batch Name</label>
                <sortable>false</sortable>
            </settings>
        </column>
        <column name="hook_name" sortOrder="50">
            <settings>
                <filter>text</filter>
                <bodyTmpl>ui/grid/cells/text</bodyTmpl>
                <label translate="true">Hook Name</label>
                <sortable>false</sortable>
            </settings>
        </column>
        <column name="level" sortOrder="60"  component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="Magento\AdobeCommerceWebhooks\Ui\Component\Listing\Log\LevelOptionSource"/>
                <filter>select</filter>
                <editor>
                    <editorType>select</editorType>
                </editor>
                <bodyTmpl>ui/grid/cells/text</bodyTmpl>
                <label translate="true">Log level</label>
                <dataType>select</dataType>
                <sortable>false</sortable>
            </settings>
        </column>
        <column name="message" sortOrder="70">
            <settings>
                <filter>text</filter>
                <bodyTmpl>ui/grid/cells/text</bodyTmpl>
                <label translate="true">Message</label>
                <sortable>false</sortable>
            </settings>
        </column>
        <column name="request_id" sortOrder="80">
            <settings>
                <filter>text</filter>
                <bodyTmpl>ui/grid/cells/text</bodyTmpl>
                <label translate="true">Request Id</label>
                <sortable>false</sortable>
            </settings>
        </column>
        <column name="created_at" sortOrder="90">
            <settings>
                <filter>dateRange</filter>
                <bodyTmpl>ui/grid/cells/text</bodyTmpl>
                <label translate="true">Date</label>
                <sortable>false</sortable>
            </settings>
        </column>
    </columns>
</listing>
