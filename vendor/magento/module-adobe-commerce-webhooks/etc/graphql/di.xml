<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <!-- Register the active quote in the registry when loaded via GetCartForUser::execute() -->
    <type name="Magento\QuoteGraphQl\Model\Cart\GetCartForUser">
        <plugin name="webhooks_register_active_quote"
                type="Magento\AdobeCommerceWebhooks\Plugin\Quote\RegisterActiveQuotePlugin"
                sortOrder="10" />
    </type>
</config>
