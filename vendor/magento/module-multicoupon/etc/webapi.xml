<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">

    <route url="/V2/carts/:cartId/coupons" method="GET">
        <service class="Magento\Multicoupon\Api\CouponManagementInterface" method="get"/>
        <resources>
            <resource ref="Magento_Cart::manage" />
        </resources>
    </route>

    <route url="/V2/carts/mine/coupons" method="GET">
        <service class="Magento\Multicoupon\Api\CouponManagementInterface" method="get"/>
        <resources>
            <resource ref="self" />
        </resources>
        <data>
            <parameter name="cartId" force="true">%cart_id%</parameter>
        </data>
    </route>

    <route url="/V2/carts/:cartId/coupons" method="POST">
        <service class="Magento\Multicoupon\Api\CouponManagementInterface" method="append"/>
        <resources>
            <resource ref="Magento_Cart::manage" />
        </resources>
    </route>

    <route url="/V2/carts/mine/coupons" method="POST">
        <service class="Magento\Multicoupon\Api\CouponManagementInterface" method="append"/>
        <resources>
            <resource ref="self" />
        </resources>
        <data>
            <parameter name="cartId" force="true">%cart_id%</parameter>
        </data>
    </route>

    <route url="/V2/carts/:cartId/coupons" method="PUT">
        <service class="Magento\Multicoupon\Api\CouponManagementInterface" method="replace"/>
        <resources>
            <resource ref="Magento_Cart::manage" />
        </resources>
    </route>

    <route url="/V2/carts/mine/coupons" method="PUT">
        <service class="Magento\Multicoupon\Api\CouponManagementInterface" method="replace"/>
        <resources>
            <resource ref="self" />
        </resources>
        <data>
            <parameter name="cartId" force="true">%cart_id%</parameter>
        </data>
    </route>

    <route url="/V2/carts/:cartId/coupons/deleteByCodes" method="POST">
        <service class="Magento\Multicoupon\Api\CouponManagementInterface" method="remove"/>
        <resources>
            <resource ref="Magento_Cart::manage" />
        </resources>
    </route>

    <route url="/V2/carts/mine/coupons/deleteByCodes" method="POST">
        <service class="Magento\Multicoupon\Api\CouponManagementInterface" method="remove"/>
        <resources>
            <resource ref="self" />
        </resources>
        <data>
            <parameter name="cartId" force="true">%cart_id%</parameter>
        </data>
    </route>

</routes>
