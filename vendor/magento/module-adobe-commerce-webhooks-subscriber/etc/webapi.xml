<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">
    <route url="/V1/webhooks/subscribe" method="POST">
        <service class="Magento\AdobeCommerceWebhooksSubscriber\Api\WebhookSubscriberInterface" method="subscribe" />
        <resources>
            <resource ref="Magento_AdobeCommerceWebhooksSubscriber::webhooks_subscribe" />
        </resources>
    </route>
    <route url="/V1/webhooks/unsubscribe" method="POST">
        <service class="Magento\AdobeCommerceWebhooksSubscriber\Api\WebhookSubscriberInterface" method="unsubscribe" />
        <resources>
            <resource ref="Magento_AdobeCommerceWebhooksSubscriber::webhooks_unsubscribe" />
        </resources>
    </route>
</routes>
