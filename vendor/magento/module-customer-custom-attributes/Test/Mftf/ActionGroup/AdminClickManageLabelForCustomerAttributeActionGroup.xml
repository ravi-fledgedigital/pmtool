<actionGroups xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:noNamespaceSchemaLocation="urn:magento:mftf:Test/etc/actionGroupSchema.xsd">
    <actionGroup name="AdminClickManageLabelForCustomerAttributeActionGroup">
        <annotations>
            <description>Clicks the "Manage Label / Options" tab on a customer attribute edit page</description>
        </annotations>
        <waitForElementClickable selector="{{AdminCustomerAttributeSection.manageLabel}}" stepKey="waitForManageLabelTab"/>
        <click selector="{{AdminCustomerAttributeSection.manageLabel}}" stepKey="clickManageLabelTab"/>
        <waitForElementVisible selector="{{AdminCustomerLastNameAttributeSection.defaultView}}" stepKey="waitForDefaultStoreViewInput"/>
    </actionGroup>
</actionGroups>
