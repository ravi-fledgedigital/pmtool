<actionGroups xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:noNamespaceSchemaLocation="urn:magento:mftf:Test/etc/actionGroupSchema.xsd">
    <actionGroup name="AdminCustomerAddressAttributeEditValidationRuleRollbackActionGroup" extends="AdminCustomerAddressAttributeEditValidationRuleActionGroup">
        <annotations>
            <description>Rolls back validation rule for customer address attribute</description>
        </annotations>
        <remove keyForRemoval="minimumTextLength"/>
        <remove keyForRemoval="maximumTextLength"/>
        <click selector="{{CustomerAddressPrefixSection.saveAndContinueEdit}}" stepKey="ClickToSave"/>
    </actionGroup>
</actionGroups>
