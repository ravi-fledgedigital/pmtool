<actionGroups xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:mftf:Test/etc/actionGroupSchema.xsd">
    <actionGroup name="AdminOpenCustomerAttributesLastNamePageActionGroup">
        <annotations>
            <description>Opens the Admin customer attribute Last Name edit page</description>
        </annotations>
        <amOnPage url="{{CustomerAttributesLastNamePage.url}}" stepKey="openCustomerAttributesLastNamePage"/>
        <waitForPageLoad stepKey="waitForPageLoad"/>
        <waitForText userInput="Last Name" stepKey="waitForPageTitle"/>
    </actionGroup>
</actionGroups>
