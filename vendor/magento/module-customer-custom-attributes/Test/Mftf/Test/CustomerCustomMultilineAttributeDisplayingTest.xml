<tests xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="urn:magento:mftf:Test/etc/testSchema.xsd">
    <test name="CustomerCustomMultilineAttributeDisplayingTest">
        <annotations>
            <group value="Customer Attribute"/>
            <stories value="Create Customer Attribute"/>
            <title value="Customer custom multiline attribute displaying"/>
            <description value="Customer custom multiline attribute displaying"/>
            <severity value="MAJOR"/>
            <testCaseId value="AC-7323"/>
            <group value="cloud"/>
        </annotations>

        <before>
            <!--Login as admin-->
            <actionGroup ref="AdminLoginActionGroup" stepKey="LoginAsAdmin"/>
            <!-- Create Customer -->
            <createData entity="Simple_US_Customer" stepKey="createCustomer"/>

            <!-- Go to Stores > Customer -->
            <amOnPage url="{{CustomerAttributesPage.url}}" stepKey="navigateToCustomerAttributes"/>
            <waitForPageLoad stepKey="waitForAttributePageLoad"/>

            <!-- Create Date Customer Custom Attribute -->
            <actionGroup ref="AdminCreateCustomerNewMultipleLineAttribute" stepKey="createMultiLineAttribute">
                <argument name="customerAttribute" value="AttributeMultiLine"/>
                <argument name="defaultLabel" value="{{AttributeMultipleLineData.label}}"/>
                <argument name="attributeCode" value="{{AttributeMultipleLineData.code}}"/>
                <argument name="inputType" value="{{AttributeMultipleLineData.inputType}}"/>
                <argument name="sortOrder" value="{{AttributeMultipleLineData.sortOrder}}"/>
                <argument name="multilineCount" value="{{AttributeMultipleLineData.multiline_count}}"/>
                <argument name="formToUse" value="Customer Registration"/>
                <argument name="message" value="You saved the customer attribute."/>
            </actionGroup>
            <actionGroup ref="CliIndexerReindexActionGroup" stepKey="reindex">
                <argument name="indices" value=""/>
            </actionGroup>
        </before>
        <after>
            <actionGroup ref="StorefrontCustomerLogoutActionGroup" stepKey="logoutCustomer" />
            <deleteData createDataKey="createCustomer" stepKey="deleteCustomer"/>
             <!--Delete customer attributes -->
            <amOnPage url="{{CustomerAttributesPage.url}}" stepKey="navigateToCustomerAttributePage"/>
            <actionGroup ref="DeleteCustomerAttribute" stepKey="adminDeleteFileAttribute">
                <argument name="defaultLabel" value="{{AttributeMultipleLineData.label}}"/>
            </actionGroup>
            <actionGroup ref="CliIndexerReindexActionGroup" stepKey="reindex">
                <argument name="indices" value=""/>
            </actionGroup>
            <actionGroup ref="CliCacheFlushActionGroup" stepKey="cliCacheFlushActionGroup">
                <argument name="tags" value="" />
            </actionGroup>
            <!--Log out-->
            <actionGroup ref="AdminLogoutActionGroup" stepKey="logOut"/>
        </after>

        <!-- Navigate to Customers -> select created customer  -->
        <actionGroup ref="AdminFilterCustomerByEmail" stepKey="filterCreatedCustomer">
            <argument name="email" value="$$createCustomer.email$$"/>
        </actionGroup>
        <click selector="{{AdminCustomerGridSection.firstRowEditLink}}" stepKey="clickOnEditButton"/>
        <waitForPageLoad stepKey="waitForCustomerEditPageToLoad"/>
        <click selector="{{AdminCustomerAccountInformationSection.accountInformationTab}}" stepKey="clickOnAccountInformation"/>
        <waitForPageLoad stepKey="waitForAccountDetailsToLoad"/>

        <!--Assert Attribute present in Customer Edit page-->
        <seeElement selector="{{AdminCustomerAccountInformationSection.customerAttribute(AttributeMultipleLineData.code)}}"  stepKey="seeTextField"/>

        <!-- Save customer with required custom attribute -->
        <fillField selector="{{AdminCustomerAccountInformationSection.customerAttributeNew(AttributeMultipleLineData.code,'1')}}" userInput="test99" stepKey="fillCustomerAttribute"/>
        <fillField selector="{{AdminCustomerAccountInformationSection.customerAttributeNew(AttributeMultipleLineData.code,'2')}}" userInput="test99" stepKey="fillCustomerAttribute2"/>
        <grabValueFrom selector="{{AdminCustomerAccountInformationSection.customerAttributeNew(AttributeMultipleLineData.code,'1')}}" stepKey="grab1"/>
        <grabValueFrom selector="{{AdminCustomerAccountInformationSection.customerAttributeNew(AttributeMultipleLineData.code,'2')}}" stepKey="grab2"/>
        <click selector="{{AdminCustomerMainActionsSection.saveButton}}" stepKey="clickOnSaveButton"/>
        <see selector="{{AdminCustomerMessagesSection.successMessage}}" userInput="You saved the customer." stepKey="seeSuccessMessage"/>
        <!-- Navigate to Customers -> select created customer  -->
        <actionGroup ref="AdminFilterCustomerByEmail" stepKey="filterCreatedCustomer2">
            <argument name="email" value="$$createCustomer.email$$"/>
        </actionGroup>
        <click selector="{{AdminCustomerGridSection.firstRowEditLink}}" stepKey="clickOnEditButton2"/>
        <waitForPageLoad stepKey="waitForCustomerEditPageToLoad2"/>
        <click selector="{{AdminCustomerAccountInformationSection.accountInformationTab}}" stepKey="clickOnAccountInformation2"/>
        <waitForPageLoad stepKey="waitForAccountDetailsToLoad2"/>
        <assertEquals  stepKey="assertAttributeValue1">
            <expectedResult type="string">test99</expectedResult>
            <actualResult type="variable">$grab1</actualResult>
        </assertEquals>
        <assertEquals  stepKey="assertAttributeValue2">
            <expectedResult type="string">test99</expectedResult>
            <actualResult type="variable">$grab2</actualResult>
        </assertEquals>
    </test>
</tests>
