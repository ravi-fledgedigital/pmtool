{
    "name": "magento/module-paypal-on-boarding",
    "description": "N/A",
    "type": "magento2-module",
    "version": "100.5.3",
    "license": [
        "proprietary"
    ],
    "repositories": {
        "repo.magento.com": {
          "type": "composer",
          "url": "https://repo.magento.com/"
        }
      },
    "require": {
        "php": "^8.1",
        "magento/module-config": "101.2.*",
        "magento/module-backend": "102.0.*",
        "magento/module-store": "101.1.*",
        "magento/module-paypal": "101.0.*",
        "magento/framework": "103.0.*"
    },
    "require-dev": {
        "php-mock/php-mock-phpunit": "^2.0",
        "phpmd/phpmd": "@stable",
        "phpstan/phpstan": "1.2.0 || ^2.0",
        "phpunit/phpunit": "^10.0 || ^12.0",
        "squizlabs/php_codesniffer": "^3.0"
    },
    "autoload-dev": {
        "psr-4": {
          "Magento\\MagentoCloud\\Test\\": "tests/static/"
        }
    },
    "scripts": {
    "test:all": [
      "@test:phpstan",
      "@test:phpcs",
      "@test:phpmd",
      "@test:unit"
    ],
    "test:phpstan": "phpstan analyse -c tests/static/phpstan.neon",
    "test:phpcs": "phpcs . --standard=tests/static/phpcs-ruleset.xml -p -n",
    "test:phpmd": "phpmd . xml tests/static/phpmd-ruleset.xml",
    "test:unit": "phpunit --configuration tests/unit"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Magento\\PaypalOnBoarding\\": ""
        }
    }
}
