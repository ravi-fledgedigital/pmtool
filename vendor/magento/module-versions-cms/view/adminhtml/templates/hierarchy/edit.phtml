/* @var \Magento\VersionsCms\Block\Adminhtml\Cms\Hierarchy\Edit\Form $block */
/** @var \Magento\Framework\View\Helper\SecureHtmlRenderer $secureRenderer */

$treeNodes = $block->getNodesJson();
$currentScope = $block->getData('current_scope');
$useDefaultScope = $block->getData('use_default_scope');
/** @var \Magento\VersionsCms\Helper\Hierarchy $hierarchyHelper */
$hierarchyHelper = $block->getData('hierarchyHelper');
?>
<div class="cms-hierarchy">

    <?= $block->getParentBlock()->getChildHtml('hierarchy_manage') ?>

    <div class="admin__page-section">
        <div class="cms-hierarchy-tree">
            <?php if ($currentScope != \Magento\VersionsCms\Model\Hierarchy\Node::NODE_SCOPE_DEFAULT): ?>
                <div class="cms-scope">
                    <input type="checkbox" name="use_default_scope"
                           id="use_default_scope" <?= $useDefaultScope ? 'checked="checked"' : '' ?>
                    <label for="use_default_scope">
                        <?= $block->escapeHtml(__('Use the parent node hierarchy.')) ?>
                    </label>
                </div>
                <?= /* @noEscape */
                $secureRenderer->renderEventListenerAsTag(
                    'onchange',
                    'hierarchyNodes.useDefaultScope()',
                    '#use_default_scope'
                ); ?>
            <?php endif; ?>

            <div class="admin__fieldset">
                <div id="tree-container" class="cms-tree tree x-tree"></div>
            </div>
        </div>

        <div class="cms-hierarchy-node">
            <div class="buttons-set">
                <?= $block->getTreeButtonsHtml() ?>
                <?= /* @noEscape */ $block->getPagePropertiesButtons() ?>
            </div>

            <div id="node_prop_container" class="entry-edit form-inline">
                <fieldset class="admin__fieldset">
                    <?= $block->getFormHtml() ?>
                </fieldset>
            </div>
        </div>
    </div>

    <!--[if IE]>
    <script id="ie-deferred-loader" defer="defer" src="//:"></script>
    <![endif]-->
    <?php
    $deleteHierarchyUrl = $block->escapeJs($block->getDeleteHierarchyUrl());
    $listModesJson = $block->getListModesJson();
    $escapedFormId = $block->escapeJs($block->getForm()->getId());
    $editPageUrl = $block->escapeJs($block->escapeUrl($block->getUrl('*/cms_page/edit')));
    $escapedStoreBaseUrl = $block->escapeJs($block->getStoreBaseUrl());
    $currentStoreUrlParam = $block->escapeJs($block->getCurrentStoreUrlParam());
    $deleteConfirmationMessage = $block->escapeJs(__("Are you sure you want to delete current hierarchy?"));
    $isDefaultScopeUsed = $useDefaultScope ? 1 : 0;
    $scriptString = <<<script
        require([
            "jquery",
            "uiRegistry",
            "Magento_Ui/js/modal/confirm",
            "escaper",
            "validation",
            "mage/mage",
            "prototype",
            "jquery/jstree/jquery.jstree"
        ], function(jQuery, registry, confirm, escaper) {

            function deleteCurrentHierarchy(){
                confirm({
                    content: '{$deleteConfirmationMessage}',
                    actions: {
                        confirm: function () {
                            document.location = '{$deleteHierarchyUrl}';
                        }
                    }
                });
            }

            const directoryTreeSelector = '#tree-container';

            hierarchyNodes = {
                nodes: {$treeNodes},
                removedNodes: \$A(),

                initialize: function () {
                    this.increment = 0;
                    this.pageIdentifiers = \$H({});
                    this.treeRoot = [{
                        text: '/',
                        id: '_root',
                        allowDrop: true,
                        allowDrag: false,
                        state: { opened: true, disabled: false, selected: false },
                        li_attr: { class: 'cms_node_root' }
                    }];

                    /**
                    * Initialize the jstree with tree root
                    */
                    jQuery(directoryTreeSelector).jstree({
                        core: {
                            data: this.treeRoot,
                            check_callback: true
                        },
                        plugins : [ 'dnd' ]
                    });

                    treeInstance = jQuery(directoryTreeSelector).jstree(true);

                    jQuery(directoryTreeSelector).on('select_node.jstree', (e, data) => {
                        this.onNodeClick(data.node);
                    });

                    jQuery(directoryTreeSelector).on('move_node.jstree', function (e, data) {
                        if (data.position === 'before' || data.position === 'after') {
                            return hierarchyNodes.onNodeAppend(treeInstance, data.parent, data.node);
                        }
                    });

                    this.createNodes();
                    treeInstance.select_node(this.treeRoot);
                    this.onNodeClick(this.treeRoot[0]);
                    this.dataModification = false;
                    this.lastChangedNode = null;
                    this.menuListTypes = {$listModesJson};

                    $('node_label').removeClassName('required-entry');
                    $('node_identifier').removeClassName('required-entry');
                    this.useDefaultScope();
                },

                treeNodesDisabler: function (node) {
                    var useDefaultScope = {$isDefaultScopeUsed};
                    if (hierarchyNodes.isDefaultScope()) {
                        if (!node.li_attr) {
                            node.li_attr = {};
                        }
                        if (!node.li_attr.class || node.li_attr.class.indexOf('disallowed') === -1) {
                            node.li_attr.class = (node.li_attr.class || '').trim() + ' disallowed';
                        }
                    } else {
                        if (node.id.indexOf('_') === -1 && useDefaultScope) {
                            var newNodeId = '_' + hierarchyNodes.increment;
                            if ($('node_id').value && $('node_id').value == node.id) {
                                $('node_id').value = newNodeId;
                            }
                            hierarchyNodes.tree.unregister_node(node);
                            node.id = newNodeId;
                            hierarchyNodes.tree.register_node(node);
                            hierarchyNodes.increment++;
                        }
                        if (node.li_attr) {
                            node.li_attr.class = (node.li_attr.class || '').replace(/\disallowed\b/, '').trim();
                        }
                    }

                    treeInstance.get_node(node.id).children.each(function (nodeId) {
                        let node = treeInstance.get_node(nodeId);
                        hierarchyNodes.treeNodesDisabler(node);
                    });
                },

                isDefaultScope: function() {
                    if ($('use_default_scope') !== null && $('use_default_scope').checked) {
                        return 1;
                    }
                    return 0;
                },

                useDefaultScope: function() {
                    let childNodes = treeInstance.get_node('_root').children;

                    childNodes.each(function (nodeId) {
                        let node = treeInstance.get_node(nodeId);
                        hierarchyNodes.treeNodesDisabler(node);
                    });

                    // Buttons that should be disabled
                    var buttons = new Array('new_node_button', 'delete_node_button', 'cancel_node_button',
                        'save_node_button', 'add_cms_pages'
                    );
                    var formId = '{$escapedFormId}';

                    if (this.isDefaultScope()) {
                        treeInstance.get_container().find('.jstree-node').addClass('disallowed');
                        buttons.each(function (name) {
                            $(name).addClassName('disabled');
                        })

                        $(formId).getElements('input').each(function (item) {
                            item.disabled = 'disabled';
                        });
                    } else {
                        // Enable visible tree nodes
                        treeInstance.get_container().find('.jstree-node').removeClass('disallowed');
                        buttons.each(function (name) {
                            $(name).removeClassName('disabled');
                        })
                        $(formId).getElements('input').each(function (item) {
                            item.disabled = false;
                        });
                    }
                },

                createNodes: function () {
                    let nodesLength = this.nodes.length;
                    for (let i = 0; i < nodesLength; i++) {
                        let cssClass = '';
                        if (!this.nodes[i].assigned_to_store) {
                            cssClass = cssClass + ' disallowed';
                        }

                        if (this.nodes[i].page_id > 0) {
                            cssClass = cssClass + ' cms_page';
                        } else {
                            cssClass = cssClass + ' cms_node';
                        }

                        let node = {
                            id: this.nodes[i].node_id,
                            text: this.nodes[i].label.stripTags(),
                            page_id: this.nodes[i].page_id,
                            identifier: this.nodes[i].identifier.stripTags(),
                            state: { opened: false, disabled: false, selected: false },
                            li_attr: { class: cssClass }
                        };

                        this.copyMetadata(this.nodes[i], node.li_attr);
                        if (this.nodes[i].page_id) {
                            this.pageIdentifiers.set(this.nodes[i].identifier, this.nodes[i].identifier.stripTags());
                        }

                        // Append the node to the tree
                        if (parentNode = this.nodes[i].parent_node_id) {
                            treeInstance.create_node(this.nodes[i].parent_node_id, node, 'last', function(newNode) {
                                hierarchyNodes.onNodeAppend(newNode);
                            });
                        } else {
                            treeInstance.create_node('_root', node, 'last', function(newNode) {
                                hierarchyNodes.onNodeAppend(newNode);
                            });
                        }
                    }
                },

                getEditPageAnchorHtml: function(pageId, pageTitle) {
                    var editUrl = '<a href="{$editPageUrl}page_id/';
                    return editUrl + pageId + '/" target="_blank">' + pageTitle + '</a>';
                },

                getNodePreviewUrlInfo: function(node) {
                    var urlKeys = [];
                    var i = 0;
                    var storeBaseUrl = '{$escapedStoreBaseUrl}';
                    var currentStoreUrlParam = '{$currentStoreUrlParam}';
                    while(node.id != '_root') {
                        urlKeys[i] = node.original.identifier;
                        node = treeInstance.get_node(node.parent);
                        i++;
                    }
                    if (urlKeys.length == 0) {
                        return false;
                    }
                    urlKeys.reverse();
                    var urlPath = urlKeys.join('/');
                    return {
                        path: urlPath,
                        url: storeBaseUrl + urlPath + currentStoreUrlParam
                    };
                },

                onNodeClick: function(node) {
                    if ($('node_id').value) {
                        this.saveNodePage();
                    }

                    if (this.lastChangedNode) {
                        this.lastChangedNode = null;
                    }

                    if (!node || node.id == '_root') {
                        $('node_prop_container').hide();
                        $('cancel_node_button').hide();
                        $('save_node_button').hide();
                        $('delete_node_button').hide();
                        this.pageGridLoad();
                        return;
                    }
                    $('node_prop_container').show();

                    var isTreeNode = node.parent == '_root';
script;
    if ($hierarchyHelper->isMetadataEnabled()) {
        $scriptString .= <<<script
                    if (isTreeNode) {
                        $('field_meta_first_last').show();
                        $('field_meta_next_previous').show();
                        $('field_meta_cs_enabled').show();
                    } else {
                        $('field_meta_first_last').hide();
                        $('field_meta_next_previous').hide();
                        $('field_meta_cs_enabled').hide();
                    }
script;
    }

    $pageFieldsetLegend = $block->escapeJs($block->getPageFieldsetLegend());
    $nodeFieldsetLegend = $block->escapeJs($block->getNodeFieldsetLegend());
    $isNodePreviewAvailable = (int)$block->isNodePreviewAvailable();
    $sameNodeMessage = $block->escapeJs(
        __('This page cannot be added, because a node or page with the same URL Key already exists in this tree part.')
    );
    $buttonSaveLabel = $block->escapeJs($block->getButtonSaveLabel());
    $buttonUpdateLabel = $block->escapeJs($block->getButtonUpdateLabel());
    $defaultMessage = $block->escapeJs($block->escapeHtml(__('Default')));
    $scriptString .= /** @lang text */
        <<<script
                    $('node_id').value = node.id;
                    $('node_page_id').value = node.original.page_id || '';

                    this.renderMetadata(node);

                    var hasPageId = node.original.page_id != null;
                    this._changeNodePropShow(hasPageId);

                    // change main fieldset title
                    $('node_properties_fieldset').down('.legend span').innerHTML = hasPageId
                        ? '{$pageFieldsetLegend}'
                        : '{$nodeFieldsetLegend}';

                    // prepare preview link
                    // Temporary solution will be removed after refactoring hierarchyNodes and validation functionality
                    jQuery('#node_id').addClass('validate-no-empty');
                    var nodeValue = $('node_id').value,
                        isNodeSaved = jQuery.validator.validateElement('#node_id')
                            || (!isNaN(parseNumber(nodeValue)) && !/^\s+$/.test(parseNumber(nodeValue))),
                        isStoreViewLevel = $('store') && $('store').value;
                    jQuery('#node_id').removeClass('validate-no-empty');

                    var isNodePreviewAvailable = {$isNodePreviewAvailable};

                    if ((isStoreViewLevel || isNodePreviewAvailable) && isNodeSaved) {
                        var nodeUrlInfo = this.getNodePreviewUrlInfo(node);
                        if (nodeUrlInfo != false) {
                            $('node_preview').up('.field').show();
                            $('node_preview').writeAttribute('target', '_blank');
                            $('node_preview').writeAttribute('href', nodeUrlInfo.url);
                            $('node_preview').innerHTML = nodeUrlInfo.path;
                        }
                    } else {
                        $('node_preview').up('.field').hide();
                    }

                    if (!hasPageId) {
                        $('node_label').value = jQuery('<div/>').html(node.text).text();
                        $('node_identifier').value = node.original.identifier;
                    } else {
                        $('node_label_text').innerHTML = this.getEditPageAnchorHtml(
                            node.original.page_id,
                            node.text.replace('\'', '&#039;').replace('"', '&quot;')
                        );
                        $('node_identifier_text').innerHTML = node.original.identifier;
                    }

                    this.nodePropReset();
                    $('delete_node_button').show();
                    $('cancel_node_button').hide();

                    this.saveButton(false);
                    this.pageGridLoad();
                },

                onNodeAppend: function(node) {
                    let parent = treeInstance.get_node(node.parent);

                    if (!parent || !node) {
                        return false;
                    }

                    let currentId = node.id,
                        currentUrlKey = node.original.identifier,
                        childrenLength = parent.children.length;

                    for (let i = 0; i < childrenLength; i++) {
                        let comparedNode = treeInstance.get_node(parent.children[i]);
                        if (comparedNode.id !== currentId && comparedNode.original.identifier === currentUrlKey) {
                            alert('{$sameNodeMessage}');
                            return false;
                        }
                    }

                    return true;
                },

                pageGridRowClick: function(container, evt){
                    var tr = evt.findElement('tr');
                    if (!tr.hasClassName('invalid')) {
                        var checkbox = tr.down('.checkbox');
                        var isInput = evt.element().tagName == 'INPUT';
                        var checked = isInput ? checkbox.checked : !checkbox.checked;
                        container.setCheckboxChecked(checkbox, checked);
                    }
                },

                pageGridAddSelected: function(){
                    if ($('add_cms_pages').hasClassName('disabled')) {
                        return false;
                    }
                    var rows = $$('#cms_page_grid_table tbody tr');
                    rows.each(function(tr){
                        var checkbox = tr.down('.checkbox');
                        if (!checkbox || !checkbox.checked) {
                            return;
                        }
                        var page_id = tr.down('.checkbox').value;
                        var label = tr.down('.col-title').getInnerText();
                        var identifier = tr.down('.col-identifier').getInnerText();

                        var rootNode = treeInstance.get_selected(true)[0];
                        if (!rootNode) {
                            rootNode = this.treeRoot;
                        }

                        treeInstance.create_node(rootNode, {
                            id: '_' + this.increment,
                            text: label,
                            identifier: identifier,
                            page_id: page_id,
                            state: { opened: true, disabled: false, selected: false },
                            li_attr: { class: 'cms_page' }
                        }, 'last');

                        this.pageIdentifiers.set(identifier, page_id);
                        this.increment ++;

                        checkbox.checked = false;

                        if (rootNode) {
                            treeInstance.open_node(rootNode);
                        }
                    }.bind(this));
                    this.pageGridLoad();
                },

                collectChilds: function(node) {
                    if (node.id == '_root') {
                        this.treeData = {};
                    } else {
                        var data = {
                            node_id: node.id,
                            parent_node_id: node.parent == '_root' ? null : node.parent,
                            page_id: node.original.page_id,
                            label: node.text,
                            identifier: node.original.identifier,
                            sort_order: treeInstance.get_node(node.parent).children.indexOf(node.id),
                            level: node.parents.length - 1
                        };
                        this.copyMetadata(node.li_attr, data);
                        this.treeData[node.id] = data;
                    }

                    if (node.children && node.children.length > 0) {
                        node.children.forEach(function (childId) {
                            var childNode = treeInstance.get_node(childId);
                            this.collectChilds(childNode);
                        }, this);
                    }
                },

                save: function() {
                    $('use_default_scope_property').value = parseInt(this.isDefaultScope());
                    if (this.isDefaultScope()) {
                        $('use_default_scope').checked = false;
                        this.useDefaultScope();
                    }

                    if (this.saveNodePage() == false) {
                        return;
                    }

                    this.collectChilds(treeInstance.get_node(this.treeRoot[0].id));
                    $('nodes_data').value = Object.toJSON(this.treeData);
                    $('removed_nodes').value = this.removedNodes.join(',');
                },

                nodePropValidate: function(){
                    $('node_label').addClassName('required-entry');
                    $('node_identifier').addClassName('required-entry');

                    var isValid = jQuery('#edit_form').mage('validation').valid();

                    $('node_label').removeClassName('required-entry');
                    $('node_identifier').removeClassName('required-entry');

                    return isValid;
                },

                nodePropReset: function(){
                    jQuery('#edit_form')
                        .mage('validation')
                        .validation('clearError');
                },

                _changeNodePropShow: function(hasPageId){
                    var nodeElements = ['node_identifier','node_label'];
                    var pageElements = ['node_identifier_text','node_label_text'];
                    pageElements.each(function(id){
                        if (!hasPageId) {
                            $(id).up('.field').hide();
                        } else {
                            $(id).up('.field').show();
                        }
                        $(id).innerHTML = '';
                    });
                    nodeElements.each(function(id){
                        if (hasPageId) {
                            $(id).up('.field').hide();
                        } else {
                            $(id).up('.field').show();
                        }
                        $(id).value = '';
                    });
                },

                newNodePage: function(){
                    if ($('new_node_button').hasClassName('disabled') || this.saveNodePage() === false) {
                        return false;
                    }

                    this.nodePropReset();
                    $('node_id').value = '';
                    $('node_page_id').value = '';
                    this._changeNodePropShow(false);
                    this.saveButton(true, false, true);
script;

    if ($hierarchyHelper->isMetadataEnabled()) {
        $scriptString .= <<<script
                    var selectedNode = treeInstance.get_selected(true)[0];
                    if (selectedNode.id == '_root') {
                        $('field_meta_first_last').show();
                        $('field_meta_next_previous').show();
                        $('field_meta_cs_enabled').show();
                    } else {
                        $('field_meta_first_last').hide();
                        $('field_meta_next_previous').hide();
                        $('field_meta_cs_enabled').hide();
                    }
script;
    }
    $scriptString .= <<<script
                    $('node_preview').up('.field').hide();
                    $('delete_node_button').hide();
                    $('node_prop_container').show();
                    $('cancel_node_button').show();

                    this.resetFieldSet('pager_fieldset');
                    this.resetFieldSet('menu_fieldset');
                    this.resetMetadataFieldSet();

                    this.renderMetadata();
                },

                cancelNodePage: function(){
                    if ($('cancel_node_button').hasClassName('disabled')) {
                        return false;
                    }
                    this.saveButton(false);
                    var selectedNodeId = treeInstance.get_selected(true)[0];
                    if (selectedNodeId && selectedNodeId !== '_root') {
                        treeInstance.select_node(selectedNodeId);
                    } else {
                        $('cancel_node_button').hide();
                        $('node_prop_container').hide();
                    }
                    this.dataModification = false;
                },

                saveNodePage: function() {
                    if (!this.dataModification || $('save_node_button').hasClassName('disabled')) {
                        return;
                    }

                    var hasNodeId = $('node_id').value != '',
                        hasPageId = $('node_page_id').value != '';

                    if (!hasPageId && !this.nodePropValidate()) {
                        return false;
                    }

                    var node;
                    if (hasNodeId) {
                        let node_id = $('node_id').value,
                            nodeData = treeInstance.get_node(node_id),
                            identifier = $('node_identifier').value.stripTags(),
                            parentData = treeInstance.get_node(nodeData.parent),
                            childrenDataLength = parentData.children.length;

                        for (let i = 0; i < childrenDataLength; i++) {
                            var comparedNode = treeInstance.get_node(parentData.children[i]);
                            if (comparedNode.id !== node_id && identifier === comparedNode.original.identifier) {
                                alert('This URL key is already in use.');
                                return false;
                            }
                        }

                        if (!hasPageId) {
                            newText = $('node_label').value.stripTags();
                            nodeData.original.identifier = identifier;
                            treeInstance.rename_node(nodeData, newText);
                        }

                        node = nodeData;
                        this.assignValuesMetadataToNode(node);
                    } else {
                        node = {
                            id: '_' + this.increment,
                            text: $('node_label').value.stripTags(),
                            identifier: $('node_identifier').value.stripTags(),
                            page_id: null,
                            state: { opened: true, disabled: false, selected: false },
                            li_attr: { class: 'cms_node' }
                        };

                        this.increment++;
                        var parentNode = treeInstance.get_selected(true)[0];

                        if (!parentNode) {
                            parentNode = this.treeRoot[0];
                        }
                        this.assignValuesMetadataToNode(node);

                        treeInstance.create_node(parentNode, node, 'last', false, false);
                        treeInstance.open_node(parentNode);
                    }

                    treeInstance.get_node(node.id, true).addClass('cms-saved');
                    this.dataModification = false;

                    if (!hasNodeId) {
                        treeInstance.select_node(node);
                    }

                    this.saveButton(false);
                },

                deleteNodePage: function() {
                    if ($('delete_node_button').hasClassName('disabled')) {
                        return false;
                    }
                    if (!$('node_id').value) {
                        return;
                    }

                    var nodeId = $('node_id').value;
                    var node = treeInstance.get_node(nodeId);
                    if (node) {
                        if (node.original.page_id) {
                            this.pageIdentifiers.unset(node.original.identifier);
                        }
                        var parentNode = treeInstance.get_node(node.parent);
                        if (parentNode) {
                            treeInstance.select_node(parentNode);
                            treeInstance.delete_node(node);
                            if (!isNaN(nodeId * 1)) {
                                this.removedNodes.push(node.id);
                            }
                        }
                        this.pageGridLoad();
                    }
                },

                checkCheckboxes: function(grid, element, checked) {
                    if (element.disabled) {
                        element.checked = false;
                    }
                },

                pageGridLoad: function() {
                    var selectedNodes = treeInstance.get_selected(true);
                    if (selectedNodes.length > 0) {
                        var node = selectedNodes[0];
                    } else {
                        var node = selectedNodes;
                    }

                    var fullReset = !node;
                    var identifiers = {};

                    if (node) {
                        node.children.forEach(function (childId) {
                            var childNode = treeInstance.get_node(childId);
                            identifiers[childNode.original.identifier] = true;
                        });

                        var rows = $$('#cms_page_grid_table tbody tr');
                        rows.each(function (tr) {
                            if (fullReset) {
                                tr.classList.remove('invalid');
                                var checkbox = tr.querySelector('.checkbox');
                                if (checkbox) {
                                    checkbox.disabled = false;
                                }
                            } else {
                                var identifierColumn = tr.querySelector('.col-identifier');
                                if (identifierColumn !== undefined) {
                                    var identifier = identifierColumn.textContent.trim();
                                    if (identifiers[identifier]) {
                                        tr.classList.add('invalid');
                                        var checkbox = tr.querySelector('.checkbox');
                                        if (checkbox) {
                                            checkbox.disabled = true;
                                        }
                                    } else {
                                        tr.classList.remove('invalid');
                                        var checkbox = tr.querySelector('.checkbox');
                                        if (checkbox) {
                                            checkbox.disabled = false;
                                        }
                                    }
                                }
                            }
                        });
                    }
                },

                hideFieldSet: function(id) {
                    $(id).hide();
                },

                showFieldSet: function(id) {
                    $(id).show();
                },

                resetFieldSet: function(id) {
                    const elems = Element.select(id, ['select', 'input', 'textarea']);
                    elems.forEach((elem) => {
                        if (elem.tagName.toLowerCase() === 'select') {
                            elem.selectedIndex = 0;
                        } else {
                            elem.value = '';
                        }
                    });
                },

                resetMetadataFieldSet: function() {
                    var defaultValue = '0';
                    var fields = [
                        'meta_first_last',
                        'meta_next_previous',
                        'meta_cs_enabled',
                        'menu_visibility',
                        'menu_excluded',
                        'top_menu_visibility',
                        'top_menu_excluded'
                    ];
                    fields.each(function(e) {
                        $(e).value = defaultValue;
                    });
                    $('meta_chapter_section').value = '';
                },

                saveButton: function(show, enabled, save) {
                    var btn = $('save_node_button');
                    if (show) {
                        btn.show();
                        btn.disabled = !enabled;
                        if (enabled) {
                            btn.removeClassName('disabled');
                        } else {
                            btn.addClassName('disabled');
                        }

                        if (save !== undefined) {
                            if (save) {
                                btn.down().update('{$buttonSaveLabel}');
                            } else {
                                btn.down().update('{$buttonUpdateLabel}');
                            }
                        }
                    } else {
                        btn.hide();
                    }
                },

                nodeChanged: function() {
                    var node = treeInstance.get_selected(true)[0];
                    if (node.id !== '_root') {
                        jQuery(node.icon).addClass('modified');
                        this.lastChangedNode = node;
                    }
                    this.dataModification = true;
                    if (!$('node_id').value) {
                        this.saveButton(true, true);
                    }
                    jQuery('#edit_form').valid();
                },

                // Navigation Menu Options List Type onChange callback
                menuListTypeChanged: function() {
                    this.nodeChanged();
                    this.renderListStyle($('menu_ordered').value);
                },

                renderListStyle: function(listType) {
                    // first remove all options from List Style drop-dawn
                    $$('#menu_list_type > option').each(function(o) {
                        o.remove();
                    });

                    var allowedTypes = this.menuListTypes[listType];
                    this.addOptionToSelect(
                        'menu_list_type',
                        '',
                        '{$defaultMessage}'
                    );
                    if (allowedTypes) {
                        Object.keys(allowedTypes).each(function(k) {
                            this.addOptionToSelect('menu_list_type', k, allowedTypes[k]);
                        }.bind(this));
                    }
                    $('menu_list_type').value = '';
                },

                getMetadataFields: function() {
                    return [
                        'meta_first_last',
                        'meta_next_previous',
                        'meta_cs_enabled',
                        'meta_chapter_section',
                        'pager_visibility',
                        'pager_frame',
                        'pager_jump',
                        'menu_visibility',
                        'menu_brief',
                        'menu_layout',
                        'menu_excluded',
                        'menu_levels_down',
                        'menu_ordered',
                        'menu_list_type',
                        'top_menu_visibility',
                        'top_menu_excluded'
                    ];
                },

                copyMetadata: function(source, dest) {
                    this.getMetadataFields().each(function(f) {
                        dest[f] = source[f];
                    }.bind(this));
                },

                assignNodeMetadataToValues: function(node) {
                    this.getMetadataFields().each(function(f) {
                        var element = $(f);
                        if (typeof element !== undefined) {
                            var value = node.li_attr[f] !== undefined ? node.li_attr[f] : '';
                            if (element.tagName.toLowerCase() == 'select') {
                                if (typeof element.defaultValue === undefined) {
                                    element.defaultValue = element.value;
                                }
                                if (value == '') {
                                    element.value = element.defaultValue;
                                } else {
                                    element.value = value;
                                }
                            } else {
                                element.value = (value == '0' ? '' : value);
                            }
                        }
                    }.bind(this));
                },

                assignValuesMetadataToNode: function(node) {
                    this.getMetadataFields().each(function(f) {
                        if ($(f) !== undefined) {
                            node.li_attr[f] = $(f).value;
                        }
                    }.bind(this));
                },

                metadataChanged: function(switcher, fieldsetId) {
                    this.nodeChanged();
                    this.toggleMetadataFieldset(switcher, fieldsetId);
                },

                toggleMetadataFieldset: function(switcher, fieldsetId) {
                    if ($(fieldsetId) !== undefined && $(switcher) !== undefined) {
                        var yes = '1';
                        var hidden = $(switcher).value != yes;
                        this.toggleFieldset($(switcher), $(fieldsetId), hidden);
                        if ($(switcher).id == 'menu_visibility') {
                            $('field_menu_excluded').hide();
                        }
                        if ($(switcher).id == 'top_menu_visibility') {
                            $('field_top_menu_excluded').hide();
                        }
                    }
                },

                toggleFieldset: function(switcher, container, hidden) {
                    var elems = Element.select(container, ['select', 'input', 'textarea', 'button']);
                    elems.each(function (elem) {
                        if (elem!=switcher) {
                            hidden ? elem.up(1).hide() : elem.up(1).show();
                        };
                    });
                },

                renderMetadata: function (node) {
                    var hasPageId = false;
                    if (node !== undefined) {
                        hasPageId = node.original.page_id != null;
                    }

                    var hasChilds = node !== undefined ? node.children.length > 0 : false;

                    // Hide pagination options anyway if node/page hasn't childs
                    hasChilds ? this.showFieldSet('pager_fieldset') : this.hideFieldSet('pager_fieldset');

                    var currentParent = node !== undefined
                        ? treeInstance.get_node(node.parent)
                        : treeInstance.get_selected(true)[0];
                    var isRootParent = currentParent.id == '_root';
                    this.toggleFieldset(null, 'menu_fieldset', !isRootParent);

                    if (!isRootParent) {
                        $('field_menu_excluded').show();
                        $('field_top_menu_excluded').show();
                        $('field_top_menu_visibility').hide();
                    } else {
                        $('field_menu_excluded').hide();
                        $('field_top_menu_excluded').hide();
                        $('field_top_menu_visibility').show();

                        // render List Type drop-down
                        if (node !== undefined) {
                            var listType = node.li_attr.menu_ordered !== undefined
                                ? node.li_attr.menu_ordered
                                : '';
                            this.renderListStyle(listType);
                        } else {
                            this.renderListStyle($('menu_ordered').value);
                        }
                    }

                    if (node !== undefined) {
                        this.assignNodeMetadataToValues(node);
                    }

                    if (isRootParent) {
                        this.toggleMetadataFieldset('menu_visibility', 'menu_fieldset');
                        this.toggleMetadataFieldset('top_menu_visibility', 'top_menu_fieldset');
                    }

                    this.toggleMetadataFieldset('pager_visibility', 'pager_fieldset');

                    var pagerVisibility = $('pager_visibility');
                    if (isRootParent) {
                        if (pagerVisibility.down('option').selected) {
                            pagerVisibility.down(2).selected=true;
                        }
                        pagerVisibility.down('option').hide();
                    } else {
                        pagerVisibility.down('option').show();
                    }
                },

                addOptionToSelect: function(selectId, optionValue, optionText) {
                    if ($(selectId) === undefined) {
                        return false;
                    }

                    if ($(selectId).down('option[value="' + optionValue + '"]') !== undefined) {
                        return false;
                    }

                    var selected = $(selectId).value;
                    var option = new Element('option', {'value': optionValue}).update(optionText);
                    $(selectId).appendChild(option);
                    $(selectId).value = selected;
                },

                removeOptionFromSelect: function (selectId, optionValue) {
                    var option = $(selectId).down('option[value="' + optionValue + '"]');
                    if (option === undefined) {
                        return false;
                    }
                    option.remove();
                }
            };

            window.deleteCurrentHierarchy = deleteCurrentHierarchy;
            jQuery(hierarchyNodes.initialize.bind(hierarchyNodes));
            registry.set('hierarchyNodes', hierarchyNodes);
        });
script;
    ?>
    <?= /* @noEscape */ $secureRenderer->renderTag('script', [], $scriptString, false); ?>

