/** @var \Magento\Framework\View\Helper\SecureHtmlRenderer $secureRenderer */
?>
<?php /** @var $block \Magento\Invitation\Block\Form */?>
<?= $block->getChildHtml('form_before') ?>
<?php
/** @var \Magento\Invitation\Helper\Data $invitationHelper */
$invitationHelper = $block->getData('invitationHelper');
?>
<?php $maxPerSend = $block->getMaxInvitationsPerSend(); ?>
<?php if ($maxPerSend): ?>
    <form id="invitationForm" action="" method="post" class="form form-add-invitations" data-mage-init='{
        "rowBuilder":{
            "rowTemplate":"#add-email-friends-tmpl",
            "rowContainer":"#invitations-options",
            "rowParentElem":"<div></div>",
            "remEventSelector":"button",
            "btnRemoveSelector":".action.remove",
            "maxRows":"<?= /* @noEscape */ (int)$block->getMaxInvitationsPerSend() ?>",
            "maxRowsMsg":"#max-emails-message",
            "addRowBtn":"#add-email-button",
            "additionalRowClass":"additional"},
        "validation":{}}'
          data-hasrequired="<?= $escaper->escapeHtmlAttr(__('* Required Fields')) ?>">

        <input name="form_key" type="hidden" value="<?= $escaper->escapeHtmlAttr($block->getFormKeyValue()) ?>" />

        <fieldset class="fieldset">
            <legend class="legend">
                <span><?= $escaper->escapeHtml(__('Invite your friends by entering their email addresses')) ?></span>
            </legend>
            <br>

            <div id="invitations-options"></div>

            <?php if ($block->isInvitationMessageAllowed()): ?>
                <div id="max-emails-message" class="message notice limit" role="alert">
                    <span>
                        <?= $escaper->escapeHtml(
                            __('Maximum %1 email addresses allowed.', $block->getMaxInvitationsPerSend())
                        ) ?>
                    </span>
                </div>
                <?php $script = 'document.querySelector("#max-emails-message").style.display = "none";'; ?>
                <?= /* @noEscape */ $secureRenderer->renderTag('script', [], $script, false); ?>
                <?= /* @noEscape */ $secureRenderer->renderTag(
                    'style',
                    [],
                    '#max-emails-message { display:none; }',
                    false
                ); ?>
            <?php endif; ?>

            <div class="actions-toolbar">
                <div class="secondary">
                    <?php if (1 < $block->getMaxInvitationsPerSend()): ?>
                        <button type="button" id="add-email-button" class="action add">
                            <span><?= $escaper->escapeHtml(__('Add')) ?></span>
                        </button>
                    <?php endif; ?>
                </div>
            </div>

            <?php if ($block->isInvitationMessageAllowed()): ?>
                <div class="field text">
                    <label for="message" class="label"><span><?= $escaper->escapeHtml(__('Message')) ?></span></label>
                    <div class="control">
                        <textarea name="message"
                                  id="message"
                                  title="<?= $escaper->escapeHtmlAttr(__('Message')) ?>"
                                  placeholder="<?= $escaper->escapeHtmlAttr(__('Message')) ?>"
                                  class="input-text"
                                  rows="5"
                                  cols="5"
                                  data-validate="{'validate-invitation-message':true}"></textarea>
                    </div>
                </div>
                <script type="text/x-magento-init">
                    {
                        "*": {
                            "Magento_Invitation/js/messageValidator" : {}
                        }
                    }
                </script>
            <?php endif;?>
        </fieldset>

        <div class="actions-toolbar">
            <div class="primary">
                <button class="action submit primary" type="submit">
                    <span><?= $escaper->escapeHtml(__('Send Invitations')) ?></span>
                </button>
            </div>
            <div class="secondary">
                <a href="<?= $escaper->escapeUrl($invitationHelper->getCustomerInvitationUrl()) ?>"
                   class="action back">
                    <span><?= $escaper->escapeHtml(__('Back to Invitations')) ?></span>
                </a>
            </div>
        </div>
    </form>

    <script id="add-email-friends-tmpl" type="text/x-magento-template">
        <fieldset class="fieldset">
            <div class="actions-toolbar">
                <div class="secondary">
                    <button type="button" id="btn-remove<%- data._index_ %>" class="action remove"
                            title="<?= $escaper->escapeHtmlAttr(__('Remove')) ?>">
                        <span><?= $escaper->escapeHtml(__('Remove')) ?></span>
                    </button>
                </div>
            </div>
            <div class="field email required">
                <label for="email_<%- data._index_ %>" class="label">
                    <span><?= $escaper->escapeHtml(__('Email')) ?></span>
                </label>
                <div class="control">
                    <input name="email[<%- data._index_ %>]" id="email_<%- data._index_ %>"
                           title="<?= $escaper->escapeHtmlAttr(__('Email')) ?>" value="" class="input-text" type="email"
                           data-validate="{required:true, 'validate-email':true}"
                           placeholder="<?= $escaper->escapeHtmlAttr(__('Enter Email')) ?>"
                    />
                </div>
            </div>
        </fieldset>
    </script>
<?php else: ?>
    <div class="message info empty">
        <span><?= $escaper->escapeHtml(__('You cannot send more invitations')) ?></span>
    </div>
    <div class="actions">
        <div class="secondary">
            <a href="<?= $escaper->escapeUrl($invitationHelper->getCustomerInvitationUrl()) ?>"
               class="action back">
                <span><?= $escaper->escapeHtml(__('Back to Invitations')) ?></span>
            </a>
        </div>
    </div>
<?php endif; ?>
