<actionGroups xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:noNamespaceSchemaLocation="urn:magento:mftf:Test/etc/actionGroupSchema.xsd">
    <actionGroup name="StoreFrontMultiShippingVerifyGiftCardActionGroup">
        <arguments>
            <argument name="shippingMethodPosition" type="string" defaultValue="1"/>
            <argument name="giftCardPosition" type="string" defaultValue="1"/>
            <argument name="actualResult" type="string" defaultValue="$0.00"/>
        </arguments>
        <grabTextFrom selector="{{ReviewOrderSection.shippingAddressGiftCardPrice(shippingMethodPosition,giftCardPosition)}}" stepKey="grabNthShippingNthGiftCardAmount"/>
        <assertEquals stepKey="verifyGiftCardAmount">
            <expectedResult type="string">$grabNthShippingNthGiftCardAmount</expectedResult>
            <actualResult type="string">{{actualResult}}</actualResult>
        </assertEquals>
    </actionGroup>
</actionGroups>
