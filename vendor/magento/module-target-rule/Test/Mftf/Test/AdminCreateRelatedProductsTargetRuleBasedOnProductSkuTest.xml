<tests xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:noNamespaceSchemaLocation="urn:magento:mftf:Test/etc/testSchema.xsd">
    <test name="AdminCreateRelatedProductsTargetRuleBasedOnProductSkuTest">
        <annotations>
            <stories value="UpdateTargetRule"/>
            <title value="Create Related Products Target Rule based on Product SKU"/>
            <description value="Create Related Products Target Rule based on Product SKU"/>
            <testCaseId value="AC-3845"/>
            <severity value="MAJOR"/>
        </annotations>
        <before>
            <createData entity="SimpleSubCategory" stepKey="createCategory"/>
            <createData entity="SimpleProduct" stepKey="createSimpleProduct1">
                <requiredEntity createDataKey="createCategory"/>
                <field key="sku">sku_simple</field>
            </createData>
            <createData entity="SimpleProduct" stepKey="createSimpleProduct2">
                <requiredEntity createDataKey="createCategory"/>
                <field key="sku">sku_related</field>
            </createData>
            <actionGroup ref="AdminLoginActionGroup" stepKey="LoginAsAdmin"/>
        </before>
        <after>
            <!--SKU Product Attribute is disable for Promo Rule Conditions-->
            <actionGroup ref="NavigateToEditProductAttributeActionGroup" stepKey="navigateToSkuProductAttribute">
                <argument name="ProductAttribute" value="sku"/>
            </actionGroup>
            <actionGroup ref="ChangeUseForPromoRuleConditionsProductAttributeActionGroup" stepKey="changeUseForPromoRuleConditionsProductAttributeToNo">
                <argument name="option" value="No"/>
            </actionGroup>
            <deleteData createDataKey="createCategory" stepKey="deleteCategory"/>
            <deleteData createDataKey="createSimpleProduct1" stepKey="deleteCreatedProduct1"/>
            <deleteData createDataKey="createSimpleProduct2" stepKey="deleteCreatedProduct2"/>
            <actionGroup ref="DeleteTargetRuleByNameActionGroup" stepKey="deleteCreatedTargetRule">
                <argument name="ruleName" value="TargetRuleRelatedProductsCategorySameAsMatchedProductCategories.ruleName"/>
            </actionGroup>
            <!-- reindex and flush cache -->
            <actionGroup ref="CliIndexerReindexActionGroup" stepKey="reindex">
                <argument name="indices" value=""/>
            </actionGroup>
            <actionGroup ref="CliCacheCleanActionGroup" stepKey="flushCache">
                <argument name="tags" value="full_page"/>
            </actionGroup>
            <actionGroup ref="AdminLogoutActionGroup" stepKey="logout"/>
        </after>
        <!--SKU Product Attribute is enabled for Promo Rule Conditions-->
        <actionGroup ref="NavigateToEditProductAttributeActionGroup" stepKey="navigateToSkuProductAttribute">
            <argument name="ProductAttribute" value="sku"/>
        </actionGroup>
        <actionGroup ref="ChangeUseForPromoRuleConditionsProductAttributeActionGroup" stepKey="changeUseForPromoRuleConditionsProductAttributeToYes">
            <argument name="option" value="Yes"/>
        </actionGroup>
        <!--Create target rule related products as per data-->
        <actionGroup ref="GoToTargetRulePage" stepKey="openTargetRulePage"/>
        <actionGroup ref="ClickAddNewTargetRule" stepKey="clickAddRule"/>
        <actionGroup ref="FillGeneralRuleInformation" stepKey="fillRuleFields">
            <argument name="information" value="TargetRuleRelatedProductsCategorySameAsMatchedProductCategories"/>
        </actionGroup>
        <fillField selector="{{AdminTargetRuleInformationSection.priority}}" userInput="20" stepKey="fillPriority"/>
        <click selector="{{AdminTargetRuleInformationSection.calendarButton('from_date')}}" stepKey="clickFromDate"/>
        <click selector="{{AdminTaxReportsSection.goTodayButton}}" stepKey="selectGoToday"/>
        <generateDate date="+10 day" format="m/d/Y" stepKey="generateToDate"/>
        <fillField selector="{{AdminTargetRuleInformationSection.to}}" userInput="{$generateToDate}" stepKey="fillToDate"/>
        <!--Fill values in Product To Match tab-->
        <click selector="{{AdminTargetRuleSection.productToMatchTab}}" stepKey="clickProductToMatchTab2"/>
        <click selector="{{AdminTargetRuleProductsToMatchSection.selectCondition('1','1')}}" stepKey="clickOnSelectCondition"/>
        <selectOption selector="{{AdminTargetRuleProductsToMatchSection.conditionSelect('1')}}" userInput="SKU" stepKey="selectSku"/>
        <waitForPageLoad stepKey="waitForProductNameLoad"/>
        <click selector="{{AdminTargetRuleProductsToMatchSection.selectCondition('1','1')}}" stepKey="clickOnIs"/>
        <selectOption selector="{{AdminTargetRuleProductsToMatchSection.newConditionOperator}}" userInput="contains" stepKey="selectNewConditionOperator"/>
        <click selector="{{AdminTargetRuleProductsToMatchSection.targetEllipsis}}" stepKey="clickTheEllipsis"/>
        <fillField selector="{{AdminTargetRuleProductsToMatchSection.ruleFieldByIndex('1--1')}}" userInput="$$createSimpleProduct1.sku$$" stepKey="fillSimpleProduct1"/>
        <!--Fill values in Product To Display tab-->
        <click selector="{{AdminTargetRuleSection.productToDisplayTab}}" stepKey="clickProductToDisplayTab"/>
        <click selector="{{AdminTargetRuleProductsToDisplaySection.selectCondition('1','1')}}" stepKey="clickToSelectCondition"/>
        <selectOption selector="{{AdminTargetRuleProductsToDisplaySection.newAction}}" userInput="SKU" stepKey="selectSkuInNewCondition"/>
        <waitForPageLoad stepKey="waitForCategoryConditionLoad2"/>
        <click selector="{{AdminTargetRuleProductsToDisplaySection.selectCondition('1','2')}}" stepKey="clickSelect"/>
        <selectOption selector="{{AdminTargetRuleProductsToDisplaySection.selectCategoryToggle('1--1')}}" userInput="Constant Value" stepKey="selectConstantValue"/>
        <click selector="{{AdminTargetRuleProductsToDisplaySection.targetEllipsis}}" stepKey="clickEllipsis"/>
        <fillField selector="{{AdminTargetRuleProductsToDisplaySection.ruleFieldByIndex('1--1')}}" userInput="$$createSimpleProduct2.sku$$" stepKey="fillSimpleProduct2"/>
        <!--Save target rule and verify AssertTargetRuleSuccessSaveMessage-->
        <actionGroup ref="SaveTargetRule" stepKey="AssertTargetRuleSuccessSaveMessage"/>
        <!--Go to storefront page and verify product1-->
        <actionGroup ref="AssertProductNameAndSkuInStorefrontProductPageByCustomAttributeUrlKeyActionGroup" stepKey="openProductPageAndVerifyProduct1">
            <argument name="product" value="$$createSimpleProduct1$$"/>
        </actionGroup>
        <!--Verify Product2 is present in related products section and AssertProductRelatedProduct-->
        <scrollTo selector="{{StorefrontProductRelatedProductsSection.relatedProductsActionsHeaderText}}" stepKey="scrollToStorefrontProductRelatedProductsSectionHeader"/>
        <seeElement selector="{{StorefrontProductRelatedProductsSection.relatedProductName($$createSimpleProduct2.name$$)}}" stepKey="seeProduct2InRelatedProductInStorefront"/>
    </test>
</tests>
