<tests xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:noNamespaceSchemaLocation="urn:magento:mftf:Test/etc/testSchema.xsd">
    <test name="AddMediaGalleryToBannerTest">
        <before>
            <magentoCLI command="config:set cms/pagebuilder/enabled 0" stepKey="turnOffPageBuilder" after="enableWYSIWYG"/>
            <actionGroup ref="CliCacheCleanActionGroup" stepKey="flushCache" after="turnOffPageBuilder">
                <argument name="tags" value="config"/>
            </actionGroup>
        </before>
        <after>
            <magentoCLI command="config:set cms/pagebuilder/enabled 1" stepKey="turnOnPageBuilder" after="disableWYSIWYG"/>
            <actionGroup ref="CliCacheCleanActionGroup" stepKey="flushCache" after="turnOnPageBuilder">
                <argument name="tags" value="config"/>
            </actionGroup>
        </after>
    </test>
</tests>
