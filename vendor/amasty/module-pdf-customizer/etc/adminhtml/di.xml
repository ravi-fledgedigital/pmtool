<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Magento\Sales\Block\Adminhtml\Order\View">
        <plugin name="amastyPDFCustomView" type="Amasty\PDFCustom\Plugin\Sales\Block\Adminhtml\Order\ViewPlugin"/>
    </type>
    <type name="Amasty\PDFCustom\Controller\Adminhtml\Template\Save">
        <arguments>
            <argument name="session" xsi:type="object">\Magento\Backend\Model\Session\Proxy</argument>
        </arguments>
    </type>
    <type name="Magento\Email\Model\AbstractTemplate">
        <plugin name="default_email_logo_converter"
                type="Amasty\PDFCustom\Plugin\Email\Model\ConvertDefaultEmailLogo"/>
    </type>
    <virtualType name="AddMpdfLibrary" type="Amasty\Base\Block\Adminhtml\System\Config\Form\Field\Promo\PromoField">
        <arguments>
            <argument name="moduleName" xsi:type="string">Amasty_PdfCustomSubscriptionFunctionality</argument>
            <argument name="promoConfig" xsi:type="array">
                <item name="promoLink" xsi:type="string">https://amasty.com/amcustomer/account/products/?utm_source=extension&amp;utm_medium=backend&amp;utm_campaign=subscribe_pdfcustomizer</item>
                <item name="comment" xsi:type="string"><![CDATA[Choose the library to use for custom PDF files generation.
                The functionality is available as part of an active product subscription or support subscription.
                To upgrade and obtain functionality, please, follow the <a href="https://amasty.com/amcustomer/account/products/?utm_source=extension&utm_medium=backend&utm_campaign=subscribe_pdfcustomizer" target="_blank">link</a>.
                Then you can find the 'amasty/module-pdf-custom-subscription-functionality'
                package for installation in composer suggest.]]></item>
            </argument>
        </arguments>
    </virtualType>
</config>
