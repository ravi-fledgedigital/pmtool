// should be insert into "before.body.end" reference container with block name "load-amfancybox.js" for single loading

use Hyva\Theme\Model\ViewModelRegistry;
use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;

/** @var Template $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */
/** @var Hyva\Theme\ViewModel\HyvaCsp|null $hyvaCsp */
?>
<script>
    (function () {
        let amFancyProcessed = false;

        window.addEventListener('load-amfancybox', () => {
            if (amFancyProcessed) {
                window?.Fancybox && window.dispatchEvent(new CustomEvent('amfancybox-loaded', {}));
                return;
            }

            const script = document.createElement('script');
            script.src = '<?= $escaper->escapeUrl(
                $block->getViewFileUrl('Amasty_LibFancybox::fancybox_ui/fancybox.min.js')
            ) ?>';
            script.async = true;
            document.body.appendChild(script);

            amFancyProcessed = true;

            script.onload = () => {
                window.dispatchEvent(new CustomEvent('amfancybox-loaded', {}));
            }

            const stylesHref = '<?= $escaper->escapeUrl(
                $block->getViewFileUrl('Amasty_LibFancybox::fancybox_ui/fancybox.min.css')
            ) ?>';

            if (document.querySelector(`link[href="${stylesHref}"]`)) {
                return;
            }

            const styles = document.createElement('link');
            styles.rel = 'stylesheet';
            styles.type = 'text/css';
            styles.href = stylesHref;

            document.head.appendChild(styles);
        });
    }());
</script>
<?php isset($hyvaCsp) && $hyvaCsp->registerInlineScript() ?>

