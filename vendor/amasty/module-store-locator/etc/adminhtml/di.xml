        </arguments>
    </type>
    <type name="Magento\ImportExport\Controller\Adminhtml\Import\Index">
        <plugin name="Amasty_Storelocator::info_message" type="Amasty\Storelocator\Plugin\ImportExport\Controller\Adminhtml\Import\Index\InfoMessage"/>
    </type>

    <!-- To build correct url during reindex from admin area -->
    <type name="Amasty\Storelocator\Model\ConfigHtmlConverter">
        <arguments>
            <argument name="urlBuilder" xsi:type="object">Magento\Framework\Url</argument>
        </arguments>
    </type>

