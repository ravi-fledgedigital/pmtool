    <virtualType name="LocatorTopCmsBlock" type="Amasty\Base\Block\Adminhtml\System\Config\Form\Field\Promo\PromoField">
        <arguments>
            <argument name="moduleName" xsi:type="string">Amasty_StorelocatorSubscriptionFunctionality</argument>
            <argument name="promoConfig" xsi:type="array">
                <item name="promoLink" xsi:type="string">https://amasty.com/amcustomer/account/products/?utm_source=extension&amp;utm_medium=backend&amp;utm_campaign=subscribe_storelocator</item>
                <item name="comment" xsi:type="string"><![CDATA[Select CMS Block that will be displayed between the title
                and main content of the Store Locator page. The functionality is available as part of an active
                product subscription or support subscription for the module. To upgrade and obtain functionality
                please follow the <a href="https://amasty.com/amcustomer/account/products/?utm_source=extension&utm_medium=backend&utm_campaign=subscribe_storelocator"
                    target="_blank">link</a>.
                Then you can find the 'amasty/module-storelocator-subscription-functionality' package for installation
                in composer suggest.]]></item>
            </argument>
        </arguments>
    </virtualType>
